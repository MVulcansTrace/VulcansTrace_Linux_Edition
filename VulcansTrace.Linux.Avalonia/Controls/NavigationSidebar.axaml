<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:models="using:VulcansTrace.Linux.Avalonia.Models"
             x:Class="VulcansTrace.Linux.Avalonia.Controls.NavigationSidebar"
             x:CompileBindings="False"
             Width="220"
             Background="{StaticResource VtBackground900Brush}">

  <Border BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0,0,1,0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ListBox x:Name="NavListBox"
               ItemsSource="{Binding NavigationItems}"
               SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0"
               Padding="0,8">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,8,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="CornerRadius" Value="0,6,6,0" />
            <Setter Property="Transitions">
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.1" />
              </Transitions>
            </Setter>
          </Style>
          <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource VtBackground700Brush}" />
          </Style>
          <Style Selector="ListBoxItem:pointerover StackPanel">
            <Setter Property="RenderTransform" Value="translateX(4px)" />
            <Setter Property="Transitions">
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
              </Transitions>
            </Setter>
          </Style>
          <Style Selector="ListBoxItem:pointerover i|Icon">
            <Setter Property="RenderTransform" Value="scale(1.1)" />
            <Setter Property="Transitions">
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
              </Transitions>
            </Setter>
          </Style>
          <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource VtBackground700Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VtPrimaryBrush}" />
          </Style>
          <Style Selector="ListBoxItem:selected TextBlock.nav-label">
            <Setter Property="Foreground" Value="{StaticResource VtTextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
          </Style>
          <Style Selector="TextBlock.group-header">
            <Setter Property="Foreground" Value="{StaticResource VtTextMutedBrush}" />
            <Setter Property="FontSize" Value="{StaticResource VtFontSizeXs}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1" />
          </Style>
          <Style Selector="ListBoxItem:selected TextBlock.group-header">
            <Setter Property="Foreground" Value="{StaticResource VtTextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
          </Style>
          <Style Selector="ListBoxItem:selected i|Icon">
            <Setter Property="Foreground" Value="{StaticResource VtPrimaryBrush}" />
            <Setter Property="RenderTransform" Value="scale(1.1)" />
            <Setter Property="Transitions">
              <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
              </Transitions>
            </Setter>
          </Style>
          <Style Selector="ListBoxItem:selected TextBlock.nav-label">
            <Setter Property="RenderTransform" Value="translateX(2px)" />
            <Setter Property="Transitions">
              <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
              </Transitions>
            </Setter>
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="models:NavigationItem">
            <StackPanel>
              <!-- Group header with separator -->
              <Border Margin="12,16,12,0"
                      BorderBrush="{StaticResource VtBorderDefaultBrush}"
                      BorderThickness="0,1,0,0"
                      IsVisible="{Binding Group, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      Opacity="0.5" />
              <TextBlock Text="{Binding Group}"
                         Classes="group-header"
                         Margin="16,12,16,4"
                         IsVisible="{Binding Group, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

              <!-- Navigation item content -->
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="12,8,12,8">
                <i:Icon Value="{Binding Icon}"
                        FontSize="20"
                        Foreground="{StaticResource VtTextSecondaryBrush}" />
                <TextBlock Text="{Binding Label}"
                           Classes="nav-label"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource VtTextSecondaryBrush}"
                           FontSize="{StaticResource VtFontSizeMd}" />
              </StackPanel>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>
  </Border>
</UserControl>
