<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:models="using:VulcansTrace.Linux.Avalonia.Models"
             x:Class="VulcansTrace.Linux.Avalonia.Controls.NavigationSidebar"
             x:CompileBindings="False"
             Background="{StaticResource VtBackground900Brush}">

  <Border BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0,0,1,0">
    <Grid RowDefinitions="Auto,*">
      <Button Grid.Row="0"
              Command="{Binding ToggleSidebarCommand}"
              IsVisible="{Binding ShowSidebarCollapseToggle}"
              AutomationProperties.AutomationId="SidebarCollapseToggle"
              AutomationProperties.Name="Toggle sidebar"
              Theme="{StaticResource VtGhostButton}"
              HorizontalAlignment="Right"
              Margin="0,4,8,0"
              Padding="8,4"
              ToolTip.Tip="Collapse or expand the sidebar">
        <i:Icon Value="{Binding SidebarCollapseToggleIcon}" FontSize="{StaticResource VtIconSizeXl}"/>
      </Button>

      <!-- Five product-level destinations replace the former sixteen-item
           feature catalog. Capability tabs live inside each destination hub. -->
      <Border Grid.Row="1" IsVisible="{Binding !IsSidebarCollapsed}" Width="220">
        <ListBox ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                 AutomationProperties.AutomationId="PrimaryNavigationList"
                 AutomationProperties.Name="Primary navigation"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,10">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="AutomationProperties.Name" Value="{Binding Label}"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0,2,8,2"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="Border.nav-row">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="3,0,0,0"/>
              <Setter Property="CornerRadius" Value="0,6,6,0"/>
            </Style>
            <Style Selector="ListBoxItem:pointerover Border.nav-row">
              <Setter Property="Background" Value="{StaticResource VtBackground700Brush}"/>
            </Style>
            <Style Selector="ListBoxItem:selected Border.nav-row">
              <Setter Property="Background" Value="{StaticResource VtBackground700Brush}"/>
              <Setter Property="BorderBrush" Value="{StaticResource VtPrimaryBrush}"/>
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBoxItem:selected i|Icon">
              <Setter Property="Foreground" Value="{StaticResource VtPrimaryBrush}"/>
            </Style>
            <Style Selector="ListBoxItem:selected TextBlock.nav-label">
              <Setter Property="Foreground" Value="{StaticResource VtTextPrimaryBrush}"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="models:NavigationItem">
              <Border Classes="nav-row" Padding="12,11,12,11"
                      AutomationProperties.AutomationId="{Binding AutomationId}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <i:Icon Value="{Binding Icon}"
                          FontSize="{StaticResource VtIconSizeLg}"
                          Foreground="{StaticResource VtTextSecondaryBrush}"/>
                  <TextBlock Text="{Binding Label}"
                             Classes="nav-label"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource VtTextSecondaryBrush}"
                             FontSize="{StaticResource VtFontSizeMd}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Border Grid.Row="1" IsVisible="{Binding IsSidebarCollapsed}" Width="56">
        <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,10">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:NavigationItem">
              <Button Command="{Binding NavigateCommand}"
                      CommandParameter="{Binding}"
                      AutomationProperties.AutomationId="{Binding AutomationId, StringFormat='{}{0}Rail'}"
                      AutomationProperties.Name="{Binding Label}"
                      Theme="{StaticResource VtGhostButton}"
                      ToolTip.Tip="{Binding Label}"
                      HorizontalAlignment="Stretch"
                      Padding="0,12">
                <Grid>
                  <Border IsVisible="{Binding IsSelected}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Width="3"
                          Background="{StaticResource VtPrimaryBrush}"/>
                  <i:Icon Value="{Binding Icon}"
                          FontSize="{StaticResource VtIconSizeLg}"
                          HorizontalAlignment="Center"/>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Grid>
  </Border>
</UserControl>
