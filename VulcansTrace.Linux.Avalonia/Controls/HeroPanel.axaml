<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:models="using:VulcansTrace.Linux.Avalonia.Models"
             x:Class="VulcansTrace.Linux.Avalonia.Controls.HeroPanel"
             x:CompileBindings="False"
             DataContext="{Binding $parent[Window].DataContext}">

    <!-- Agent-home hero: the UNIFIED input surface (UI v2 Phase 3). One box
         serves chat questions and pasted logs; the primary action flips
         Chat ↔ Analyze by a deterministic content heuristic
         (MainViewModel.IsLogIntent). Bindings target MainViewModel via the
         window DataContext (compiled bindings off — same pattern as
         NavigationSidebar). Agent-thread members bind via the Agent. prefix. -->
    <Border Theme="{StaticResource VtCard}" Padding="12" Margin="0,0,0,6">
        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding ShowHeroIntro}">
                <Ellipse Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Top">
                    <Ellipse.Fill>
                        <ImageBrush Source="/Assets/VulcansTraceAvatar.png"/>
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="New analysis"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource VtFontSizeMd}"
                               Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    <TextBlock Text="{Binding BotIntroText}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource VtFontSizeSm}"
                               Foreground="{StaticResource VtTextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Advisor tip (superseded by the summary card once a thread exists) -->
            <Border IsVisible="{Binding ShowAdvisorTip}"
                    Background="{StaticResource VtBackground800Brush}"
                    BorderBrush="{StaticResource VtBorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VtRadiusXl}"
                    Padding="8"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tip:" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="{StaticResource VtPrimaryBrush}"/>
                    <ScrollViewer Grid.Column="1"
                                  MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalAlignment="Top">
                        <TextBlock Text="{Binding AdvisorMessage}" TextWrapping="Wrap" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Slash command palette (moved from the retired bottom chat input;
                 ids unchanged so existing scenarios keep resolving) -->
            <Border Background="{StaticResource VtBackground700Brush}"
                    BorderBrush="{StaticResource VtBorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource VtRadiusMd}"
                    Padding="8"
                    IsVisible="{Binding Agent.IsSlashPaletteOpen}">
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Agent.FilteredSlashCommands}"
                             AutomationProperties.AutomationId="AgentSlashCommandPaletteList"
                             AutomationProperties.Name="Agent slash command palette"
                             SelectedItem="{Binding Agent.SelectedSlashCommand}"
                             Focusable="False"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="2" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:SlashCommandItem">
                                <Button Command="{Binding Command}"
                                        AutomationProperties.Name="{Binding CommandText}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,8"
                                        Theme="{StaticResource VtSecondaryButton}">
                                    <StackPanel Orientation="Vertical" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding CommandText}"
                                                       FontFamily="{StaticResource VtFontFamilyMono}"
                                                       FontSize="{StaticResource VtFontSizeSm}"
                                                       Foreground="{StaticResource VtPrimaryBrush}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="{StaticResource VtFontSizeSm}"
                                                       Foreground="{StaticResource VtTextPrimaryBrush}"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="{StaticResource VtFontSizeXs}"
                                                   Foreground="{StaticResource VtTextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- Unified input row: one box, one flipping primary action -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         x:Name="HeroInputBox"
                         Theme="{StaticResource VtInput}"
                         Text="{Binding LogText, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask anything, or paste firewall log lines…"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="44"
                         MaxHeight="140"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource VtFontFamilyMono}"
                         FontSize="{StaticResource VtFontSizeSm}"
                         KeyDown="OnHeroInputKeyDown"
                         LostFocus="OnHeroInputLostFocus"
                         AutomationProperties.AutomationId="HeroInputBox"
                         AutomationProperties.Name="Agent input" />
                <Button Grid.Column="1"
                        Theme="{StaticResource VtSecondaryButton}"
                        Command="{Binding Agent.OpenSlashHelpCommand}"
                        VerticalAlignment="Bottom"
                        Height="44"
                        AutomationProperties.AutomationId="AgentSlashHelpButton"
                        AutomationProperties.Name="Command help"
                        ToolTip.Tip="Show command help (Ctrl+K)">
                    <i:Icon Value="mdi-help-circle-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        Theme="{StaticResource VtPrimaryButton}"
                        Command="{Binding HeroPrimaryCommand}"
                        VerticalAlignment="Bottom"
                        Height="44"
                        Padding="16,0"
                        AutomationProperties.AutomationId="HeroPrimaryButton"
                        AutomationProperties.Name="{Binding HeroPrimaryLabel}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <i:Icon Value="{Binding HeroPrimaryIcon}" FontSize="{StaticResource VtIconSizeMd}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HeroPrimaryLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Suggested-prompt chips: fill the input, never auto-send -->
            <ItemsControl ItemsSource="{Binding PromptChips}"
                          IsVisible="{Binding ShowHeroIntro}"
                          AutomationProperties.AutomationId="PromptChipItems"
                          AutomationProperties.Name="Suggested prompts">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:PromptChip">
                        <Button Content="{Binding Label}"
                                Command="{Binding DataContext.PromptChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="10,6"
                                Margin="0,0,8,6"
                                Theme="{StaticResource VtSecondaryButton}"
                                AutomationProperties.AutomationId="{Binding AutomationId}"
                                AutomationProperties.Name="{Binding Label}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Scan options -->
            <Expander Header="Scan options"
                      IsExpanded="False"
                      Theme="{StaticResource VtExpander}"
                      AutomationProperties.AutomationId="ScanOptionsExpander"
                      AutomationProperties.Name="Scan options">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ScanIntensityLabel"
                               Text="Scan intensity:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    <ComboBox ItemsSource="{Binding Intensities}"
                              SelectedItem="{Binding SelectedIntensity}"
                              AutomationProperties.AutomationId="IntensityComboBox"
                              AutomationProperties.Name="Scan intensity"
                              AutomationProperties.LabeledBy="{Binding ElementName=ScanIntensityLabel}"
                              Theme="{StaticResource VtComboBox}"/>
                    <TextBlock Text="Low shows only High/Critical findings. Medium shows Medium+. High shows all severities."
                               Foreground="{StaticResource VtTextSecondaryBrush}"
                               FontSize="{StaticResource VtFontSizeSm}"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="MachineRoleLabel"
                               Text="Machine role:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    <ComboBox ItemsSource="{Binding MachineRoles}"
                              SelectedItem="{Binding SelectedMachineRole}"
                              AutomationProperties.AutomationId="MachineRoleComboBox"
                              AutomationProperties.Name="Machine role"
                              AutomationProperties.LabeledBy="{Binding ElementName=MachineRoleLabel}"
                              Theme="{StaticResource VtComboBox}"/>

                    <!-- Advanced numerics + session HMAC info moved into a dialog
                         (UI v2 Phase 2); the expander keeps only intensity + role. -->
                    <Button Theme="{StaticResource VtGhostButton}"
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            Command="{Binding AdvancedScanOptionsCommand}"
                            AutomationProperties.AutomationId="AdvancedScanOptionsButton"
                            AutomationProperties.Name="Advanced scan options">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <i:Icon Value="mdi-tune" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                            <TextBlock Text="Advanced..." FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Expander>
        </StackPanel>
    </Border>
</UserControl>
