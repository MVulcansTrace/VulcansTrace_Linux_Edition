<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
             xmlns:local="using:VulcansTrace.Linux.Avalonia.Views"
             xmlns:suggestions="using:VulcansTrace.Linux.Agent.Suggestions"
             xmlns:sessions="using:VulcansTrace.Linux.Agent.Sessions"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="VulcansTrace.Linux.Avalonia.Views.AgentView"
             x:DataType="vm:AgentViewModel">

  <Design.DataContext>
    <vm:AgentViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <conv:BoolToAlignmentConverter x:Key="BoolToAlignment" />
    <conv:MessageBubbleBackgroundConverter x:Key="MessageBubbleBackground" />
    <conv:MessageBubbleBorderBrushConverter x:Key="MessageBubbleBorderBrush" />
    <conv:MessageBubbleForegroundConverter x:Key="MessageBubbleForeground" />
    <conv:AgentStatusToBackgroundBrushConverter x:Key="AgentStatusToBackgroundBrush" />
    <conv:AgentStatusToForegroundBrushConverter x:Key="AgentStatusToForegroundBrush" />

    <DataTemplate x:Key="AgentQuickActionTemplate" DataType="vm:AgentQuickAction">
      <Button Command="{Binding Command}"
              Padding="10,8"
              Margin="0,0,8,6"
              Theme="{StaticResource VtSecondaryButton}"
              AutomationProperties.AutomationId="{Binding AutomationId}"
              AutomationProperties.Name="{Binding Label}">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <i:Icon Value="{Binding Icon}" FontSize="{StaticResource VtIconSizeXs}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Label}" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </DataTemplate>
    <conv:BoolToDoubleConverter x:Key="BoolToMaxHeight" TrueValue="1200" FalseValue="0" />
    <conv:BoolToDoubleConverter x:Key="BoolToOpacity" TrueValue="1" FalseValue="0" />
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="24">

    <!-- Header -->
    <Border Grid.Row="0"
            Theme="{StaticResource VtCard}"
            Padding="16,12"
            Margin="0,0,0,12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
          <controls:VtAgentAvatar AvatarSize="36" AvatarFontSize="{StaticResource VtFontSizeSm}" />
          <StackPanel Orientation="Vertical" VerticalAlignment="Center">
            <TextBlock Text="Security Agent"
                       FontSize="{StaticResource VtFontSizeXl}"
                       FontWeight="Bold"
                       Foreground="{StaticResource VtTextPrimaryBrush}" />
            <TextBlock Text="Ask in plain language, get audits, explanations, and remediation plans."
                       FontSize="{StaticResource VtFontSizeSm}"
                       Foreground="{StaticResource VtTextSecondaryBrush}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Theme="{StaticResource VtBadge}" Background="{Binding AgentStatus, Converter={StaticResource AgentStatusToBackgroundBrush}}">
            <TextBlock Text="{Binding AgentStatus}" FontSize="{StaticResource VtFontSizeXs}" Foreground="{Binding AgentStatus, Converter={StaticResource AgentStatusToForegroundBrush}}" FontWeight="SemiBold" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Agent Tools toggle -->
    <Border Grid.Row="1"
            Theme="{StaticResource VtCard}"
            Padding="12"
            Margin="0,0,0,12">
      <Button Theme="{StaticResource VtSecondaryButton}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Command="{Binding ToggleAgentToolsPanelCommand}"
              AutomationProperties.AutomationId="AgentToolsToggleButton"
              AutomationProperties.Name="Toggle Agent Tools panel">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <i:Icon Value="mdi-tools" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
          <TextBlock Text="Agent Tools" VerticalAlignment="Center" FontWeight="SemiBold" />
          <i:Icon Value="mdi-chevron-down" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" IsVisible="{Binding !IsAgentToolsPanelOpen}" />
          <i:Icon Value="mdi-chevron-up" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" IsVisible="{Binding IsAgentToolsPanelOpen}" />
        </StackPanel>
      </Button>
    </Border>

    <!-- Agent Tools panel -->
    <Border Grid.Row="2"
            Theme="{StaticResource VtAgentToolsPanel}"
            Margin="0,0,0,12"
            MaxHeight="{Binding IsAgentToolsPanelOpen, Converter={StaticResource BoolToMaxHeight}}"
            Opacity="{Binding IsAgentToolsPanelOpen, Converter={StaticResource BoolToOpacity}}"
            IsHitTestVisible="{Binding IsAgentToolsPanelOpen}">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    MaxHeight="470">
        <WrapPanel Orientation="Horizontal">
          <!-- Analysis -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="220" MaxWidth="380" Margin="0,0,24,12">
            <TextBlock Text="Analysis" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ToolPanelAnalysisActions}" ItemTemplate="{StaticResource AgentQuickActionTemplate}" AutomationProperties.AutomationId="AgentAnalysisActionsList" AutomationProperties.Name="Agent analysis actions">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>

          <!-- Run checks -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="220" MaxWidth="380" Margin="0,0,24,12">
            <TextBlock Text="Run checks" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ToolPanelRunCheckActions}" ItemTemplate="{StaticResource AgentQuickActionTemplate}" AutomationProperties.AutomationId="AgentRunCheckActionsList" AutomationProperties.Name="Agent run check actions">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>

          <!-- Baseline -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="220" MaxWidth="380" Margin="0,0,24,12">
            <TextBlock Text="Baseline" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ToolPanelBaselineActions}" ItemTemplate="{StaticResource AgentQuickActionTemplate}" AutomationProperties.AutomationId="AgentBaselineActionsList" AutomationProperties.Name="Agent baseline actions">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>

          <!-- Export -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="220" MaxWidth="380" Margin="0,0,24,12">
            <TextBlock Text="Export" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding ToolPanelExportActions}" ItemTemplate="{StaticResource AgentQuickActionTemplate}" AutomationProperties.AutomationId="AgentExportActionsList" AutomationProperties.Name="Agent export actions">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>

          <!-- History &amp; Sessions -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="900" MaxWidth="1200" Margin="0,0,0,12">
            <TextBlock Text="History &amp; Sessions" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
              <Expander Grid.Column="0"
                        Header="Audit History"
                        Theme="{StaticResource VtExpander}"
                        IsExpanded="False">
                <StackPanel Margin="8" Spacing="8">
                  <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                    <ComboBox Grid.Column="0"
                              AutomationProperties.AutomationId="AgentAuditHistoryBeforeComboBox"
                              AutomationProperties.Name="Audit history before snapshot"
                              ItemsSource="{Binding History}"
                              SelectedItem="{Binding SelectedBeforeEntry}"
                              Theme="{StaticResource VtComboBox}"
                              PlaceholderText="Before"
                              MaxDropDownHeight="160" />
                    <TextBlock Grid.Column="1"
                               Text="to"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource VtTextMutedBrush}" />
                    <ComboBox Grid.Column="2"
                              AutomationProperties.AutomationId="AgentAuditHistoryAfterComboBox"
                              AutomationProperties.Name="Audit history after snapshot"
                              ItemsSource="{Binding History}"
                              SelectedItem="{Binding SelectedAfterEntry}"
                              Theme="{StaticResource VtComboBox}"
                              PlaceholderText="After"
                              MaxDropDownHeight="160" />
                  </Grid>

                  <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding History}" AutomationProperties.AutomationId="AgentAuditHistoryList" AutomationProperties.Name="Agent audit history">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Spacing="6" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{StaticResource VtBackground700Brush}"
                                  BorderBrush="{StaticResource VtBorderDefaultBrush}"
                                  BorderThickness="1"
                                  CornerRadius="{StaticResource VtRadiusMd}"
                                  Padding="8,6">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss}}"
                                         Foreground="{StaticResource VtTextMutedBrush}"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Intent}"
                                         Foreground="{StaticResource VtTextPrimaryBrush}"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="2"
                                         Text="{Binding TotalFindings, StringFormat='Findings: {0}'}"
                                         Foreground="{StaticResource VtTextSecondaryBrush}"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="3"
                                         Text="{Binding PassedCount, StringFormat='Passed: {0}'}"
                                         Foreground="{StaticResource VtSuccessBrush}"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="4"
                                         Text="✓ Exported"
                                         Foreground="{StaticResource VtSuccessBrush}"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         IsVisible="{Binding Exported}"
                                         VerticalAlignment="Center"
                                         AutomationProperties.Name="Exported" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </Expander>

              <Expander Grid.Column="1"
                        Header="Remediation Sessions"
                        Theme="{StaticResource VtExpander}"
                        IsExpanded="False">
                <StackPanel Margin="8" Spacing="8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh"
                            Theme="{StaticResource VtSecondaryButton}"
                            Command="{Binding ListSessionsCommand}"
                            AutomationProperties.AutomationId="AgentRemediationSessionsRefreshButton"
                            AutomationProperties.Name="Refresh remediation sessions" />
                    <Button Content="Resume"
                            Theme="{StaticResource VtSecondaryButton}"
                            Command="{Binding ResumeSessionCommand}"
                            AutomationProperties.AutomationId="AgentRemediationSessionResumeButton"
                            AutomationProperties.Name="Resume remediation session" />
                    <Button Content="Delete"
                            Theme="{StaticResource VtGhostButton}"
                            Command="{Binding DeleteSessionCommand}"
                            AutomationProperties.AutomationId="AgentRemediationSessionDeleteButton"
                            AutomationProperties.Name="Delete remediation session" />
                  </StackPanel>

                  <ListBox ItemsSource="{Binding Sessions}"
                           AutomationProperties.AutomationId="AgentRemediationSessionsList"
                           AutomationProperties.Name="Remediation sessions"
                           SelectedItem="{Binding SelectedSession}"
                           MaxHeight="180"
                           Background="Transparent"
                           BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="sessions:RemediationSession">
                        <Border Background="{StaticResource VtBackground700Brush}"
                                BorderBrush="{StaticResource VtBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource VtRadiusMd}"
                                Padding="8,6"
                                Margin="0,0,0,6">
                          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SessionId}"
                                       Foreground="{StaticResource VtTextPrimaryBrush}"
                                       FontSize="{StaticResource VtFontSizeSm}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RemediationPlan.Sections[0].FindingSummary, FallbackValue='No summary'}"
                                       Foreground="{StaticResource VtTextSecondaryBrush}"
                                       FontSize="{StaticResource VtFontSizeXs}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Status}"
                                       Foreground="{StaticResource VtTextSecondaryBrush}"
                                       FontSize="{StaticResource VtFontSizeXs}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding CreatedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                       Foreground="{StaticResource VtTextMutedBrush}"
                                       FontSize="{StaticResource VtFontSizeXs}"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Expander>
            </Grid>
          </StackPanel>

          <!-- Pinned messages -->
          <StackPanel Orientation="Vertical" Spacing="8" MinWidth="900" MaxWidth="1200" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Pinned messages"
                         FontSize="{StaticResource VtFontSizeXs}"
                         Foreground="{StaticResource VtTextMutedBrush}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
              <TextBlock Text="{Binding PinnedMessageCountLabel}"
                         FontSize="{StaticResource VtFontSizeXs}"
                         Foreground="{StaticResource VtTextMutedBrush}"
                         VerticalAlignment="Center"
                         IsVisible="{Binding HasPinnedMessages}" />
              <Button Content="Toggle pin for latest agent message"
                      AutomationProperties.AutomationId="AgentLatestMessagePinButton"
                      AutomationProperties.Name="Toggle pin for latest agent message"
                      Theme="{StaticResource VtGhostButton}"
                      FontSize="{StaticResource VtFontSizeXs}"
                      Padding="6,2"
                      Command="{Binding TogglePinMessageCommand}"
                      CommandParameter="{Binding LatestPinnableMessage}"
                      IsVisible="{Binding HasLatestPinnableMessage}" />
              <Button Content="{Binding LatestSuggestedFollowUpLabel}"
                      AutomationProperties.AutomationId="AgentLatestSuggestionButton"
                      AutomationProperties.Name="Run latest suggested follow-up"
                      AutomationProperties.HelpText="{Binding LatestSuggestedFollowUpLabel}"
                      Theme="{StaticResource VtGhostButton}"
                      FontSize="{StaticResource VtFontSizeXs}"
                      Padding="6,2"
                      Command="{Binding RunLatestSuggestedFollowUpCommand}"
                      IsVisible="{Binding HasLatestSuggestedFollowUp}" />
            </StackPanel>

            <TextBlock Text="{Binding PinMessageStatusMessage}"
                       MaxWidth="600"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding PinMessageStatusMessage}"
                       Foreground="{StaticResource VtSeverityMediumBrush}"
                       FontSize="{StaticResource VtFontSizeSm}"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasPinMessageStatusMessage}" />

            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasPinnedMessages}">
              <ItemsControl ItemsSource="{Binding PinnedMessages}" AutomationProperties.AutomationId="AgentPinnedMessagesList" AutomationProperties.Name="Pinned agent messages">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Spacing="6" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:AgentMessageViewModel">
                    <Border Background="{StaticResource VtBackground700Brush}"
                            BorderBrush="{StaticResource VtBorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VtRadiusMd}"
                            Padding="8,6">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                        <i:Icon Grid.Column="0"
                                Value="{Binding PinIcon}"
                                FontSize="{StaticResource VtIconSizeXs}"
                                Foreground="{StaticResource VtPrimaryBrush}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Text}"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding FormattedTimestamp}"
                                   Foreground="{StaticResource VtTextMutedBrush}"
                                   FontSize="{StaticResource VtFontSizeXs}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="3"
                                AutomationProperties.Name="{Binding PinTooltip}"
                                Theme="{StaticResource VtGhostButton}"
                                Padding="4,2"
                                ToolTip.Tip="{Binding PinTooltip}"
                                Command="{Binding TogglePinCommand}"
                                CommandParameter="{Binding}">
                          <i:Icon Value="{Binding PinIcon}"
                                  FontSize="{StaticResource VtIconSizeXs}"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource VtPrimaryBrush}" />
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock Text="No pinned messages yet. Pin a message from the chat transcript to save it here."
                       FontSize="{StaticResource VtFontSizeSm}"
                       Foreground="{StaticResource VtTextSecondaryBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="600"
                       IsVisible="{Binding !HasPinnedMessages}" />
          </StackPanel>

        </WrapPanel>
      </ScrollViewer>
    </Border>

    <!-- Chat -->
    <Border Grid.Row="3"
            Theme="{StaticResource VtCard}"
            Padding="0"
            Margin="0,0,0,12">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <Border Grid.Row="0"
                Background="{StaticResource VtWarningMutedBrush}"
                BorderBrush="{StaticResource VtWarningBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource VtRadiusMd}"
                Padding="10,8"
                Margin="16,16,16,8"
                IsVisible="{Binding HasPrivilegeWarning}">
          <TextBlock Text="{Binding PrivilegeWarningText}"
                     TextWrapping="Wrap"
                     FontSize="{StaticResource VtFontSizeSm}"
                     Foreground="{StaticResource VtWarningBrush}" />
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="16,16,16,12">
          <TextBlock x:Name="SeverityFilterLabel" Text="Severity:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding ChatSeverityFilters}"
                    SelectedItem="{Binding SelectedChatSeverityFilter}"
                    Theme="{StaticResource VtComboBox}"
                    MinWidth="150"
                    MaxDropDownHeight="160"
                    AutomationProperties.AutomationId="AgentChatSeverityFilter"
                    AutomationProperties.Name="Agent chat severity filter"
                    AutomationProperties.LabeledBy="{Binding ElementName=SeverityFilterLabel}" />
          <TextBlock x:Name="CategoryFilterLabel" Text="Category:" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource VtTextSecondaryBrush}" />
          <ComboBox ItemsSource="{Binding ChatCategoryFilters}"
                    SelectedItem="{Binding SelectedChatCategoryFilter}"
                    Theme="{StaticResource VtComboBox}"
                    MinWidth="150"
                    MaxDropDownHeight="160"
                    PlaceholderText="All categories"
                    AutomationProperties.AutomationId="AgentChatCategoryFilter"
                    AutomationProperties.Name="Category filter"
                    AutomationProperties.LabeledBy="{Binding ElementName=CategoryFilterLabel}" />
          <Button Theme="{StaticResource VtGhostButton}"
                  Command="{Binding ClearChatFiltersCommand}"
                  AutomationProperties.AutomationId="AgentClearChatFiltersButton"
                  AutomationProperties.Name="Clear filters">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <i:Icon Value="mdi-close-circle-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
              <TextBlock Text="Clear" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Active filter chips -->
        <ItemsControl Grid.Row="2"
                       AutomationProperties.AutomationId="AgentActiveChatFiltersList"
                       AutomationProperties.Name="Active agent chat filters"
                       ItemsSource="{Binding ActiveChatFilterChips}"
                       Margin="16,0,16,12">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ChatFilterChipViewModel">
              <Button Command="{Binding RemoveCommand}"
                      AutomationProperties.Name="{Binding Label}"
                      Padding="8,4"
                      Margin="0,0,8,6"
                      Theme="{StaticResource VtGhostButton}">
                <Border Background="{StaticResource VtBackground700Brush}"
                        BorderBrush="{StaticResource VtBorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VtRadiusMd}"
                        Padding="8,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Label}"
                               FontSize="{StaticResource VtFontSizeSm}"
                               Foreground="{StaticResource VtTextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <i:Icon Value="mdi-close" FontSize="{StaticResource VtIconSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Chat search -->
        <Grid Grid.Row="3"
              RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto"
              Margin="16,0,16,12"
              IsVisible="{Binding !HasOnlyWelcomeMessage}">
          <TextBox Grid.Row="0"
                   Grid.Column="0"
                   x:Name="ChatSearchBox"
                   Theme="{StaticResource VtInput}"
                   Text="{Binding ChatSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Search chat..."
                   KeyDown="OnChatSearchKeyDown"
                   AutomationProperties.AutomationId="AgentChatSearchInput"
                   AutomationProperties.Name="Search chat messages" />
          <Button Grid.Row="0"
                  Grid.Column="1"
                  Theme="{StaticResource VtGhostButton}"
                  Command="{Binding ClearChatSearchCommand}"
                  Margin="8,0,0,0"
                  AutomationProperties.AutomationId="AgentChatSearchClearButton"
                  AutomationProperties.Name="Clear chat search">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <i:Icon Value="mdi-close-circle-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
              <TextBlock Text="Clear" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <TextBlock Grid.Row="1"
                     Grid.Column="0"
                     Grid.ColumnSpan="2"
                     Text="{Binding ChatSearchEmptyStateText}"
                     FontSize="{StaticResource VtFontSizeSm}"
                     Foreground="{StaticResource VtTextSecondaryBrush}"
                     IsVisible="{Binding HasNoSearchMatches}"
                     Margin="0,6,0,0" />
        </Grid>

      <ListBox x:Name="ChatListBox"
               Grid.Row="4"
               Classes="VtChatList"
               ItemsSource="{Binding Messages}"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               Margin="16,0,16,16"
               AutomationProperties.Name="Agent chat messages">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:AgentMessageViewModel">
            <Grid ColumnDefinitions="Auto,*"
                  HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignment}}"
                  IsVisible="{Binding IsRowVisible}"
                  AutomationProperties.Name="{Binding AutomationName}"
                  AutomationProperties.AutomationId="{Binding MessageId, StringFormat='AgentMessage_{0}'}">
                <!-- Avatar -->
                <controls:VtAgentAvatar Grid.Column="0"
                                        AvatarSize="28"
                                        AvatarFontSize="{StaticResource VtFontSizeXs}"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        IsVisible="{Binding !IsUser}" />

                <!-- Message bubble -->
                <Border Grid.Column="1"
                        Background="{Binding Converter={StaticResource MessageBubbleBackground}}"
                        BorderBrush="{Binding Converter={StaticResource MessageBubbleBorderBrush}}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VtRadiusLg}"
                        Padding="16">
                  <Grid>
                    <StackPanel Orientation="Vertical" Spacing="12" IsVisible="{Binding !IsStreaming}">

                    <!-- Timestamp + pin action -->
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ShowTimestamp}">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding FormattedTimestamp}"
                                 TextAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignment}}"
                                 FontSize="{StaticResource VtFontSizeXs}"
                                 Foreground="{StaticResource VtTextMutedBrush}"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="1"
                              Theme="{StaticResource VtGhostButton}"
                              Padding="4,2"
                              Margin="8,0,0,0"
                              ToolTip.Tip="{Binding PinTooltip}"
                              Command="{Binding TogglePinCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding CanBePinned}"
                              AutomationProperties.AutomationId="AgentMessagePinButton"
                              AutomationProperties.Name="Toggle pin for agent message">
                        <i:Icon Value="{Binding PinIcon}"
                                FontSize="{StaticResource VtIconSizeXs}"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource VtPrimaryBrush}" />
                      </Button>
                    </Grid>

                    <!-- Rich text blocks: paragraphs, inline formatting, code blocks with copy buttons -->
                    <ItemsControl ItemsSource="{Binding FormattedBlocks}" AutomationProperties.Name="Agent message content">
                      <ItemsControl.DataTemplates>
                        <DataTemplate DataType="vm:ParagraphBlock">
                          <TextBlock TextWrapping="Wrap"
                                     FontSize="{StaticResource VtFontSizeMd}"
                                     LineHeight="30"
                                     conv:FormattedTextBlock.InlinesSource="{Binding Inlines}"
                                     Foreground="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource MessageBubbleForeground}}" />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CodeBlock">
                          <Border Background="{StaticResource VtCodeBackgroundBrush}"
                                  BorderBrush="{StaticResource VtCodeBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="{StaticResource VtRadiusMd}"
                                  Padding="12">
                            <Grid RowDefinitions="Auto,*">
                              <Grid Grid.Row="0"
                                    ColumnDefinitions="*,Auto,Auto"
                                    Margin="0,0,0,8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Language}"
                                           FontSize="{StaticResource VtFontSizeXs}"
                                           Foreground="{StaticResource VtTextMutedBrush}"
                                           FontWeight="SemiBold"
                                           IsVisible="{Binding Language, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Copy"
                                        AutomationProperties.Name="Copy code block"
                                        Theme="{StaticResource VtGhostButton}"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        Command="{Binding CopyCommand}" />
                                <Button Grid.Column="2"
                                        Theme="{StaticResource VtGhostButton}"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="6,2"
                                        Margin="4,0,0,0"
                                        Command="{Binding ToggleExpandCommand}"
                                        AutomationProperties.AutomationId="AgentCodeBlock_ToggleExpand"
                                        AutomationProperties.Name="Collapse or expand code block">
                                  <Grid>
                                    <i:Icon Value="mdi-chevron-down"
                                            FontSize="{StaticResource VtIconSizeXs}"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsExpanded}" />
                                    <i:Icon Value="mdi-chevron-right"
                                            FontSize="{StaticResource VtIconSizeXs}"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding !IsExpanded}" />
                                  </Grid>
                                </Button>
                              </Grid>
                              <TextBlock Grid.Row="1"
                                         Text="{Binding Code}"
                                         FontFamily="{StaticResource VtFontFamilyMono}"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         Foreground="{StaticResource VtCodeForegroundBrush}"
                                         TextWrapping="Wrap"
                                         IsVisible="{Binding IsExpanded}" />
                              <TextBlock Grid.Row="1"
                                         Text="{Binding PreviewText}"
                                         FontFamily="{StaticResource VtFontFamilyMono}"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         Foreground="{StaticResource VtTextMutedBrush}"
                                         TextWrapping="NoWrap"
                                         TextTrimming="CharacterEllipsis"
                                         IsVisible="{Binding !IsExpanded}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.DataTemplates>
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Vertical" Spacing="12" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- Details -->
                    <TextBlock Text="{Binding Details}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource VtTextSecondaryBrush}"
                               FontSize="{StaticResource VtFontSizeSm}"
                               LineHeight="26"
                               IsVisible="{Binding Details, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                    <!-- Confidence / Signals -->
                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding HasConfidence}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Confidence" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" />
                        <TextBlock Text="{Binding Confidence}" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtInfoBrush}" FontWeight="Bold" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasEvidenceSignals}">
                        <TextBlock Text="Signals" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" />
                        <TextBlock Text="{Binding EvidenceSignalsDisplay}"
                                   FontSize="{StaticResource VtFontSizeXs}"
                                   Foreground="{StaticResource VtTextSecondaryBrush}" />
                      </StackPanel>
                    </StackPanel>

                    <!-- Verification commands -->
                    <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasVerificationCommands}">
                      <TextBlock Text="How to verify" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
                      <ItemsControl ItemsSource="{Binding VerificationCommands}" AutomationProperties.Name="Verification commands">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Spacing="6" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <local:CommandRow />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <!-- Remediation plan card -->
                    <Border Background="{StaticResource VtBackground900Brush}"
                            BorderBrush="{StaticResource VtBorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource VtRadiusMd}"
                            Padding="16"
                            IsVisible="{Binding HasRemediationSection}">
                      <StackPanel Orientation="Vertical" Spacing="16">

                        <!-- Impact preview -->
                        <Border Background="{StaticResource VtBackground800Brush}"
                                BorderBrush="{StaticResource VtBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource VtRadiusSm}"
                                Padding="12"
                                IsVisible="{Binding HasImpactPreview}">
                          <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock Text="Impact preview"
                                       FontSize="{StaticResource VtFontSizeXs}"
                                       Foreground="{StaticResource VtPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="6">
                              <TextBlock Grid.Row="0"
                                         Grid.Column="0"
                                         Text="Expected impact"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         Foreground="{StaticResource VtTextMutedBrush}" />
                              <TextBlock Grid.Row="0"
                                         Grid.Column="1"
                                         Text="{Binding ImpactPreviewExpectedImpact}"
                                         TextWrapping="Wrap"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         Foreground="{StaticResource VtTextSecondaryBrush}" />

                              <TextBlock Grid.Row="1"
                                         Grid.Column="0"
                                         Text="Risk"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         Foreground="{StaticResource VtTextMutedBrush}" />
                              <StackPanel Grid.Row="1"
                                          Grid.Column="1"
                                          Orientation="Horizontal"
                                          Spacing="6">
                                <TextBlock Text="{Binding ImpactPreviewRiskBefore}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Foreground="{StaticResource VtWarningBrush}" />
                                <TextBlock Text="→"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Foreground="{StaticResource VtTextMutedBrush}" />
                                <TextBlock Text="{Binding ImpactPreviewExpectedRiskAfter}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Foreground="{StaticResource VtSuccessBrush}" />
                              </StackPanel>

                              <TextBlock Grid.Row="2"
                                         Grid.Column="0"
                                         Text="Commands"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         Foreground="{StaticResource VtTextMutedBrush}" />
                              <TextBlock Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding ImpactPreviewCommandCount}"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         Foreground="{StaticResource VtTextSecondaryBrush}" />

                              <TextBlock Grid.Row="3"
                                         Grid.Column="0"
                                         Text="Rollback"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         Foreground="{StaticResource VtTextMutedBrush}" />
                              <StackPanel Grid.Row="3"
                                          Grid.Column="1"
                                          Orientation="Vertical"
                                          Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <Border Theme="{StaticResource VtBadge}"
                                          Background="{StaticResource VtSuccessMutedBrush}"
                                          IsVisible="{Binding ImpactPreviewRollbackAvailable}">
                                    <TextBlock Text="ROLLBACK"
                                               FontSize="{StaticResource VtFontSizeXs}"
                                               Foreground="{StaticResource VtSuccessBrush}"
                                               FontWeight="SemiBold" />
                                  </Border>
                                  <Border Theme="{StaticResource VtBadge}"
                                          Background="{StaticResource VtDangerMutedBrush}"
                                          IsVisible="{Binding ImpactPreviewRollbackUnavailable}">
                                    <TextBlock Text="NO ROLLBACK"
                                               FontSize="{StaticResource VtFontSizeXs}"
                                               Foreground="{StaticResource VtDangerBrush}"
                                               FontWeight="SemiBold" />
                                  </Border>
                                  <TextBlock Text="{Binding ImpactPreviewRollbackAvailabilityLabel}"
                                             FontSize="{StaticResource VtFontSizeSm}"
                                             Foreground="{StaticResource VtTextSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding ImpactPreviewRollbackPath}"
                                           TextWrapping="Wrap"
                                           FontFamily="{Binding RollbackPathFontFamily}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Foreground="{StaticResource VtTextSecondaryBrush}" />
                              </StackPanel>

                              <TextBlock Grid.Row="4"
                                         Grid.Column="0"
                                         Text="Verify"
                                         FontSize="{StaticResource VtFontSizeXs}"
                                         Foreground="{StaticResource VtTextMutedBrush}" />
                              <TextBlock Grid.Row="4"
                                         Grid.Column="1"
                                         Text="{Binding ImpactPreviewVerificationCommand}"
                                         TextWrapping="Wrap"
                                         FontFamily="{Binding ImpactPreviewVerificationFontFamily}"
                                         FontSize="{StaticResource VtFontSizeSm}"
                                         Foreground="{StaticResource VtTextSecondaryBrush}" />

                              <StackPanel Grid.Row="5"
                                          Grid.Column="1"
                                          Orientation="Vertical"
                                          Spacing="6">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            IsVisible="{Binding ImpactPreviewHasRestartImpact}">
                                  <Border Theme="{StaticResource VtBadge}"
                                          Background="{StaticResource VtWarningMutedBrush}">
                                    <TextBlock Text="RESTART"
                                               FontSize="{StaticResource VtFontSizeXs}"
                                               Foreground="{StaticResource VtWarningBrush}"
                                               FontWeight="SemiBold" />
                                  </Border>
                                  <TextBlock Text="{Binding ImpactPreviewRestartImpactDescription}"
                                             TextWrapping="Wrap"
                                             FontSize="{StaticResource VtFontSizeSm}"
                                             Foreground="{StaticResource VtTextSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            IsVisible="{Binding ImpactPreviewHasLockoutRisk}">
                                  <Border Theme="{StaticResource VtBadge}"
                                          Background="{StaticResource VtDangerMutedBrush}">
                                    <TextBlock Text="LOCKOUT"
                                               FontSize="{StaticResource VtFontSizeXs}"
                                               Foreground="{StaticResource VtDangerBrush}"
                                               FontWeight="SemiBold" />
                                  </Border>
                                  <TextBlock Text="{Binding ImpactPreviewLockoutRiskDescription}"
                                             TextWrapping="Wrap"
                                             FontSize="{StaticResource VtFontSizeSm}"
                                             Foreground="{StaticResource VtTextSecondaryBrush}" />
                                </StackPanel>
                              </StackPanel>
                            </Grid>
                          </StackPanel>
                        </Border>

                        <!-- Preconditions -->
                        <StackPanel Orientation="Vertical" Spacing="6" IsVisible="{Binding HasPreconditions}">
                          <TextBlock Text="Before you apply" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding RemediationPreconditions}" AutomationProperties.Name="Remediation preconditions">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="4" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="☐" FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextMutedBrush}" />
                                  <TextBlock Text="{Binding}" FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Backup -->
                        <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasBackupCommands}">
                          <TextBlock Text="Backup first" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtWarningBrush}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding RemediationBackupCommands}" AutomationProperties.Name="Remediation backup commands">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <local:CommandRow />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Apply -->
                        <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasApplyCommands}">
                          <TextBlock Text="Apply fix" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtDangerBrush}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding RemediationApplyCommands}" AutomationProperties.Name="Remediation apply commands">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <local:CommandRow />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Rollback -->
                        <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasRollbackCommands}">
                          <TextBlock Text="If something goes wrong" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtSuccessBrush}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding RemediationRollbackCommands}" AutomationProperties.Name="Remediation rollback commands">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <local:CommandRow />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Verification -->
                        <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasRemediationVerificationCommands}">
                          <TextBlock Text="Verify the fix" FontSize="{StaticResource VtFontSizeXs}" Foreground="{StaticResource VtTextMutedBrush}" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding RemediationVerificationCommands}" AutomationProperties.Name="Remediation verification commands">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <local:CommandRow />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Countermeasures -->
                        <StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding HasCountermeasureCommands}">
                          <TextBlock Text="Countermeasures"
                                     FontSize="{StaticResource VtFontSizeXs}"
                                     Foreground="{StaticResource VtDangerBrush}"
                                     FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding CountermeasureCommands}" AutomationProperties.Name="Remediation countermeasure commands">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <local:CommandRow />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Button Content="Deploy Countermeasures"
                                  Theme="{StaticResource VtSecondaryButton}"
                                  Foreground="{StaticResource VtDangerBrush}"
                                  BorderBrush="{StaticResource VtDangerBrush}"
                                  HorizontalAlignment="Left"
                                  Command="{Binding $parent[ListBox].DataContext.DeployCountermeasuresCommand}"
                                  CommandParameter="{Binding RemediationSection}"
                                  AutomationProperties.AutomationId="AgentDeployCountermeasuresButton"
                                  AutomationProperties.Name="Deploy Countermeasures" />
                        </StackPanel>

                      </StackPanel>
                    </Border>

                    <!-- Guided remediation session -->
                    <StackPanel Orientation="Vertical"
                                Spacing="10"
                                IsVisible="{Binding HasActiveSession}">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Session"
                                   FontSize="{StaticResource VtFontSizeXs}"
                                   Foreground="{StaticResource VtTextMutedBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionStatus}"
                                   FontSize="{StaticResource VtFontSizeXs}"
                                   Foreground="{StaticResource VtInfoBrush}"
                                   FontWeight="SemiBold" />
                      </StackPanel>
                      <Button Content="Verify Remediation"
                              Theme="{StaticResource VtSecondaryButton}"
                              HorizontalAlignment="Left"
                              Command="{Binding $parent[ListBox].DataContext.VerifySessionCommand}"
                              CommandParameter="{Binding SessionId}"
                              AutomationProperties.AutomationId="AgentVerifyRemediationButton"
                              AutomationProperties.Name="Verify Remediation" />
                    </StackPanel>

                    <StackPanel Orientation="Vertical"
                                Spacing="8"
                                IsVisible="{Binding HasSessionTimeline}">
                      <TextBlock Text="Timeline"
                                 FontSize="{StaticResource VtFontSizeXs}"
                                 Foreground="{StaticResource VtTextMutedBrush}"
                                 FontWeight="SemiBold" />
                      <ItemsControl ItemsSource="{Binding SessionTimeline}" AutomationProperties.Name="Remediation session timeline">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Spacing="6" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="sessions:RemediationSessionEvent">
                            <Border Background="{StaticResource VtBackground900Brush}"
                                    BorderBrush="{StaticResource VtBorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource VtRadiusSm}"
                                    Padding="10">
                              <StackPanel Orientation="Vertical" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss}}"
                                             FontSize="{StaticResource VtFontSizeXs}"
                                             Foreground="{StaticResource VtTextMutedBrush}" />
                                  <TextBlock Text="{Binding Type}"
                                             FontSize="{StaticResource VtFontSizeXs}"
                                             Foreground="{StaticResource VtInfoBrush}"
                                             FontWeight="SemiBold" />
                                  <TextBlock Text="{Binding RuleId}"
                                             FontSize="{StaticResource VtFontSizeXs}"
                                             Foreground="{StaticResource VtTextMutedBrush}"
                                             IsVisible="{Binding RuleId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Foreground="{StaticResource VtTextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Details}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource VtFontSizeXs}"
                                           Foreground="{StaticResource VtTextSecondaryBrush}"
                                           IsVisible="{Binding Details, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <!-- Suggestion chips -->
                    <WrapPanel Orientation="Horizontal" IsVisible="{Binding HasSuggestions}">
                      <ItemsControl ItemsSource="{Binding Suggestions}" AutomationProperties.Name="Suggested follow-up actions">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="suggestions:SuggestedFollowUp">
                          <Button Content="{Binding Label}"
                                    AutomationProperties.Name="{Binding Label}"
                                    Theme="{StaticResource VtGhostButton}"
                                    Margin="0,0,8,8"
                                    Command="{Binding $parent[ItemsControl].DataContext.SuggestionCommand}"
                                    CommandParameter="{Binding}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </WrapPanel>

                    </StackPanel>

                    <!-- Streaming/typewriter state: plain text + blinking cursor -->
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="4"
                          VerticalAlignment="Top"
                          IsVisible="{Binding IsStreaming}"
                          AutomationProperties.AutomationId="AgentStreamingMessage"
                          AutomationProperties.Name="{Binding AutomationName}">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding StreamingText}"
                                 TextWrapping="Wrap"
                                 FontSize="{StaticResource VtFontSizeMd}"
                                 LineHeight="30"
                                 Foreground="{Binding Converter={StaticResource MessageBubbleForeground}}" />
                      <Border Grid.Column="1"
                              Width="2"
                              Height="16"
                              Background="{StaticResource VtPrimaryBrush}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,4"
                              Classes="streamingCursor">
                        <Border.Styles>
                          <Style Selector="Border.streamingCursor">
                            <Style.Animations>
                              <Animation Duration="0:0:0.8" IterationCount="Infinite">
                                <KeyFrame Cue="0%">
                                  <Setter Property="Opacity" Value="0" />
                                </KeyFrame>
                                <KeyFrame Cue="50%">
                                  <Setter Property="Opacity" Value="1" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                  <Setter Property="Opacity" Value="0" />
                                </KeyFrame>
                              </Animation>
                            </Style.Animations>
                          </Style>
                        </Border.Styles>
                      </Border>
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Welcome suggestions overlay -->
        <!-- Intentionally stretches to fill the chat cell so the list's own welcome bubble cannot show through. -->
        <Border Grid.Row="4"
                Background="{StaticResource VtBackground900Brush}"
                BorderBrush="{StaticResource VtBorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource VtRadiusLg}"
                Margin="16,0,16,16"
                Padding="32"
                IsVisible="{Binding HasOnlyWelcomeMessage}"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Opacity="1">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CircularEaseOut" />
            </Transitions>
          </Border.Transitions>
          <Grid RowDefinitions="Auto,Auto,Auto,*"
                HorizontalAlignment="Center"
                MaxWidth="900">
            <i:Icon Grid.Row="0"
                    Value="mdi-shield-search"
                    FontSize="{StaticResource VtIconSize2xl}"
                    Foreground="{StaticResource VtPrimaryBrush}"
                    HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1"
                       Text="What would you like to check?"
                       FontSize="{StaticResource VtFontSizeLg}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource VtTextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0" />
            <TextBlock Grid.Row="2"
                       Text="Open Agent Tools to run a check, or type your own question below."
                       FontSize="{StaticResource VtFontSizeSm}"
                       Foreground="{StaticResource VtTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
          </Grid>
        </Border>

        <!-- Filter empty state -->
        <controls:FilterEmptyStateView Grid.Row="4"
                                       AutomationProperties.AutomationId="AgentFilterEmptyState"
                                       AutomationProperties.Name="Agent chat filter empty state"
                                       Icon="mdi-filter-remove-outline"
                                       Headline="No matching messages"
                                       Description="Try clearing the filters to see all results."
                                       IsVisible="{Binding HasNoVisibleFilterMessages}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       Margin="16,0,16,16" />

        <!-- Agent progress / typing indicator -->
        <Grid Grid.Row="5"
              ColumnDefinitions="Auto,*"
              HorizontalAlignment="Left"
              Margin="16,8,16,16"
              IsVisible="{Binding IsBusy}">
          <controls:VtAgentAvatar Grid.Column="0"
                                  AvatarSize="28"
                                  AvatarFontSize="{StaticResource VtFontSizeXs}"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Top" />
          <Border Grid.Column="1"
                  Background="{StaticResource VtPrimaryGlowBrush}"
                  BorderBrush="{StaticResource VtPrimaryBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource VtRadiusLg}"
                  Padding="16,12"
                  VerticalAlignment="Top"
                  MinWidth="240">
            <StackPanel Orientation="Vertical" Spacing="8">
              <!-- Progress bar + label for audit operations -->
              <StackPanel Orientation="Vertical"
                          Spacing="4"
                          IsVisible="{Binding ShowAuditProgress}">
                <TextBlock Text="{Binding AuditProgressMessage}"
                           Foreground="{StaticResource VtTextPrimaryBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           FontWeight="SemiBold"
                           AutomationProperties.AutomationId="AgentAuditProgressLabel"
                           AutomationProperties.Name="Audit progress status" />
                <ProgressBar Value="{Binding AuditProgressPercent}"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding AuditProgressIsIndeterminate}"
                             Classes="VtAuditProgress"
                             AutomationProperties.AutomationId="AgentAuditProgressBar"
                             AutomationProperties.Name="Audit progress" />
              </StackPanel>
              <!-- Typing dots for non-audit busy states -->
              <StackPanel Orientation="Horizontal"
                          Spacing="4"
                          VerticalAlignment="Center"
                          IsVisible="{Binding !ShowAuditProgress}"
                          Classes.busy="{Binding IsBusy}">
                <StackPanel.Styles>
                  <Style Selector="StackPanel.busy Ellipse:nth-child(1)">
                    <Style.Animations>
                      <Animation Duration="0:0:0.6" IterationCount="Infinite">
                        <KeyFrame Cue="0%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                          <Setter Property="Opacity" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                      </Animation>
                    </Style.Animations>
                  </Style>
                  <Style Selector="StackPanel.busy Ellipse:nth-child(2)">
                    <Style.Animations>
                      <Animation Duration="0:0:0.6" IterationCount="Infinite" Delay="0:0:0.15">
                        <KeyFrame Cue="0%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                          <Setter Property="Opacity" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                      </Animation>
                    </Style.Animations>
                  </Style>
                  <Style Selector="StackPanel.busy Ellipse:nth-child(3)">
                    <Style.Animations>
                      <Animation Duration="0:0:0.6" IterationCount="Infinite" Delay="0:0:0.3">
                        <KeyFrame Cue="0%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                        <KeyFrame Cue="50%">
                          <Setter Property="Opacity" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                          <Setter Property="Opacity" Value="0.4" />
                        </KeyFrame>
                      </Animation>
                    </Style.Animations>
                  </Style>
                </StackPanel.Styles>
                <Ellipse Width="6" Height="6" Fill="{StaticResource VtPrimaryBrush}" />
                <Ellipse Width="6" Height="6" Fill="{StaticResource VtPrimaryBrush}" />
                <Ellipse Width="6" Height="6" Fill="{StaticResource VtPrimaryBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <!-- Input area -->
    <Border Grid.Row="4" Theme="{StaticResource VtCard}" Padding="16" Margin="0,0,0,12">
      <StackPanel Orientation="Vertical" Spacing="0">
        <!-- Slash command palette -->
        <Border Background="{StaticResource VtBackground700Brush}"
                BorderBrush="{StaticResource VtBorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource VtRadiusMd}"
                Padding="8"
                Margin="0,0,0,12"
                IsVisible="{Binding IsSlashPaletteOpen}">
          <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
            <ListBox ItemsSource="{Binding FilteredSlashCommands}"
                     AutomationProperties.AutomationId="AgentSlashCommandPaletteList"
                     AutomationProperties.Name="Agent slash command palette"
                     SelectedItem="{Binding SelectedSlashCommand}"
                     Focusable="False"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="2" />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SlashCommandItem">
                  <Button Command="{Binding Command}"
                          AutomationProperties.Name="{Binding CommandText}"
                          CommandParameter="{Binding}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="10,8"
                          Theme="{StaticResource VtSecondaryButton}">
                    <StackPanel Orientation="Vertical" Spacing="2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding CommandText}"
                                   FontFamily="{StaticResource VtFontFamilyMono}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   Foreground="{StaticResource VtPrimaryBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Title}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                      </StackPanel>
                      <TextBlock Text="{Binding Description}"
                                 FontSize="{StaticResource VtFontSizeXs}"
                                 Foreground="{StaticResource VtTextSecondaryBrush}" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
        </Border>

        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
          <TextBox Grid.Column="0"
                   x:Name="AgentQueryInput"
                   Theme="{StaticResource VtInput}"
                   Text="{Binding UserQuery, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Ask the agent or type / for commands..."
                   KeyDown="OnQueryKeyDown"
                   LostFocus="OnQueryLostFocus"
                   VerticalAlignment="Center"
                   AutomationProperties.AutomationId="AgentQueryInput"
                   AutomationProperties.Name="Agent query input" />
          <Button Grid.Column="1"
                  Theme="{StaticResource VtSecondaryButton}"
                  Command="{Binding OpenSlashHelpCommand}"
                  VerticalAlignment="Center"
                  AutomationProperties.AutomationId="AgentSlashHelpButton"
                  AutomationProperties.Name="Command help"
                  ToolTip.Tip="Show command help (Ctrl+K)">
            <i:Icon Value="mdi-help-circle-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
          </Button>
          <Button Grid.Column="2"
                  Theme="{StaticResource VtPrimaryButton}"
                  Content="Send"
                  Command="{Binding SendQueryCommand}"
                  VerticalAlignment="Center"
                  AutomationProperties.AutomationId="AgentSendButton"
                  AutomationProperties.Name="Send" />
          <Button Grid.Column="3"
                  Theme="{StaticResource VtSecondaryButton}"
                  Content="Cancel"
                  Command="{Binding CancelQueryCommand}"
                  IsVisible="{Binding IsBusy}"
                  VerticalAlignment="Center"
                  AutomationProperties.AutomationId="AgentCancelButton"
                  AutomationProperties.Name="Cancel agent query" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Slash command help overlay -->
    <Border Grid.Row="1"
            Grid.RowSpan="3"
            Theme="{StaticResource VtCard}"
            Padding="16"
            Margin="0,0,0,12"
            IsVisible="{Binding IsSlashHelpOpen}"
            AutomationProperties.AutomationId="AgentSlashHelpOverlay"
            AutomationProperties.Name="Agent command help overlay">
      <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <i:Icon Value="mdi-help-circle-outline" FontSize="{StaticResource VtIconSizeMd}" Foreground="{StaticResource VtPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="Available commands" FontSize="{StaticResource VtFontSizeLg}" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
          <Button Grid.Column="1"
                  Theme="{StaticResource VtGhostButton}"
                  Command="{Binding CloseSlashHelpCommand}"
                  AutomationProperties.AutomationId="AgentSlashHelpCloseButton"
                  AutomationProperties.Name="Close Agent command help">
            <i:Icon Value="mdi-close" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center" />
          </Button>
        </Grid>

        <!-- Search -->
        <TextBox Grid.Row="1"
                 x:Name="SlashHelpSearchBox"
                 Theme="{StaticResource VtInput}"
                 Text="{Binding SlashHelpQuery, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search commands..."
                 Margin="0,0,0,12"
                 KeyDown="OnSlashHelpKeyDown"
                 AutomationProperties.AutomationId="AgentSlashHelpSearchInput"
                 AutomationProperties.Name="Search Agent commands" />

        <!-- Results -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
          <ListBox ItemsSource="{Binding FilteredSlashHelpCommands}"
                   AutomationProperties.AutomationId="AgentSlashHelpResultsList"
                   AutomationProperties.Name="Agent command help results"
                   SelectedItem="{Binding SelectedSlashHelpCommand}"
                   Focusable="False"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="2" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:SlashCommandItem">
                <Button Command="{Binding Command}"
                        AutomationProperties.Name="{Binding CommandText}"
                        CommandParameter="{Binding}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"
                        Theme="{StaticResource VtSecondaryButton}">
                  <StackPanel Orientation="Vertical" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding CommandText}"
                                 FontFamily="{StaticResource VtFontFamilyMono}"
                                 FontSize="{StaticResource VtFontSizeSm}"
                                 Foreground="{StaticResource VtPrimaryBrush}"
                                 FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Title}"
                                 FontSize="{StaticResource VtFontSizeSm}"
                                 Foreground="{StaticResource VtTextPrimaryBrush}"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Text="{Binding Description}"
                               FontSize="{StaticResource VtFontSizeXs}"
                               Foreground="{StaticResource VtTextSecondaryBrush}" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</UserControl>
