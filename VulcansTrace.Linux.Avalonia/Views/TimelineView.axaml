<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.TimelineView"
             x:DataType="vm:TimelineViewModel">

    <Design.DataContext>
        <vm:TimelineViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="150,*">
            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Background="{DynamicResource BackgroundSecondary}"
                        Margin="0">
                <ToggleButton x:Name="TraceMapToggle"
                              Content="Trace Map"
                              Margin="8,4"
                              Padding="8,2"
                              IsChecked="{Binding IsTraceMapEnabled}"
                              Foreground="{DynamicResource TextPrimary}"
                              Background="{DynamicResource BackgroundTertiary}"/>
                <ToggleButton x:Name="HostGroupToggle"
                              Content="Group by Host"
                              Margin="0,4,8,4"
                              Padding="8,2"
                              IsChecked="{Binding GroupMode, Converter={StaticResource GroupModeToBoolConverter}}"
                              Foreground="{DynamicResource TextPrimary}"
                              Background="{DynamicResource BackgroundTertiary}"
                              IsEnabled="{Binding IsTraceMapEnabled}"/>
            </StackPanel>

            <!-- Category/Host labels column -->
            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource BackgroundSecondary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1">
                <TextBlock Text="{Binding RowHeaderLabel}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <ItemsControl ItemsSource="{Binding Categories}" Margin="4,6,4,6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Margin="4,0"
                                       Height="22"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Timeline visualization area -->
            <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BackgroundSecondary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding TimeRangeLabel}"
                           Margin="8,4"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiary}"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource BackgroundPrimary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0">
                <Grid>
                    <Canvas x:Name="TimelineCanvas"
                            Background="{DynamicResource BackgroundPrimary}"
                            Height="{Binding CanvasHeight}">
                        <!-- Timeline bars and edges will be drawn here -->
                    </Canvas>
                    <TextBlock Text="{Binding SuppressionMessage}"
                               IsVisible="{Binding IsEdgeRenderingSuppressed}"
                               VerticalAlignment="Bottom"
                               Margin="8,4"
                               FontSize="11"
                               Foreground="{DynamicResource Warning}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Narrative panel -->
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource BackgroundSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    IsVisible="{Binding IsNarrativeVisible}">
                <TextBlock Text="{Binding SelectedChainNarrative}"
                           Margin="8,6"
                           FontSize="12"
                           Foreground="{DynamicResource TextTertiary}"
                           TextWrapping="Wrap"
                           FontStyle="Italic"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
