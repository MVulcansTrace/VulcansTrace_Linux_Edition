<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
             x:Class="VulcansTrace.Linux.Avalonia.Views.TimelineView"
             x:DataType="vm:TimelineViewModel">

    <Design.DataContext>
        <vm:TimelineViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <conv:TimelineEntryLabelConverter x:Key="TimelineEntryLabelConverter" />
    </UserControl.Resources>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" ColumnDefinitions="150,*">
            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        Background="{StaticResource VtBackground800Brush}"
                        Margin="0">
                <ToggleButton x:Name="TraceMapToggle"
                              Content="Trace Map"
                              Margin="8,4"
                              Padding="8,2"
                              IsChecked="{Binding IsTraceMapEnabled}"
                              Theme="{StaticResource VtToggleButton}"/>
                <ToggleButton x:Name="HostGroupToggle"
                              Content="Group by Host"
                              Margin="0,4,8,4"
                              Padding="8,2"
                              IsChecked="{Binding GroupMode, Converter={StaticResource GroupModeToBoolConverter}}"
                              Theme="{StaticResource VtToggleButton}"
                              IsEnabled="{Binding IsTraceMapEnabled}"/>
            </StackPanel>

            <!-- Category/Host labels column -->
            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource VtBackground800Brush}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0,0,1,1">
                <TextBlock Text="{Binding RowHeaderLabel}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{StaticResource VtTextPrimaryBrush}"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="0" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0,0,1,0">
                <ItemsControl ItemsSource="{Binding RowLabels}" Margin="4,40,4,6" AutomationProperties.AutomationId="TimelineRowLabelsList" AutomationProperties.Name="Timeline row labels">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="22" VerticalAlignment="Center" Margin="4,0">
                                <TextBlock Text="{Binding}"
                                           Height="22"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding}"
                                           Foreground="{StaticResource VtTextSecondaryBrush}"
                                           Margin="4,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Timeline visualization area -->
            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource VtBackground800Brush}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding HasTimelineData}">
                <TextBlock Text="{Binding TimeRangeLabel}"
                           Margin="8,4"
                           FontSize="{StaticResource VtFontSizeMd}"
                           Foreground="{StaticResource VtTextMutedBrush}"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="0">
                <Grid Height="{Binding CanvasHeight}" ClipToBounds="True">
                    <Canvas x:Name="TimelineCanvas"
                            Background="{StaticResource VtBackground900Brush}"
                            Height="{Binding CanvasHeight}">
                        <!-- Timeline axis, grid, markers, edges and selection glow will be drawn here -->
                    </Canvas>
                    <TextBlock Text="{Binding SuppressionMessage}"
                               IsVisible="{Binding IsEdgeRenderingSuppressed}"
                               VerticalAlignment="Bottom"
                               Margin="8,4"
                               FontSize="{StaticResource VtFontSizeSm}"
                               Foreground="{StaticResource VtWarningBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Selected finding detail card -->
                    <Border Theme="{StaticResource VtCard}"
                            Padding="12"
                            Margin="16"
                            MaxWidth="360"
                            MaxHeight="188"
                            MinWidth="260"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource VtBackground800Brush}"
                            IsVisible="{Binding IsFindingSelected}"
                            x:Name="DetailCard">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10"
                                             VerticalAlignment="Center"
                                             Fill="{Binding SelectedEntry.Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                                    <TextBlock Text="{Binding SelectedEntry.Category, Converter={StaticResource CategoryLabelConverter}}"
                                               FontWeight="Bold"
                                               FontSize="{StaticResource VtFontSizeMd}"
                                               Foreground="{StaticResource VtTextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        x:Name="CloseDetailButton"
                                        AutomationProperties.AutomationId="TimelineCloseDetailButton"
                                        AutomationProperties.Name="Close timeline finding details"
                                        Theme="{StaticResource VtGhostButton}"
                                        Padding="6"
                                        VerticalAlignment="Top">
                                    <i:Icon Value="mdi-close" FontSize="{StaticResource VtIconSizeSm}" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                </Button>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding SelectedEntry.Severity}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding SelectedEntry.Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}"/>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Source:"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextMutedBrush}"
                                               Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding SelectedEntry.SourceHost}"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextSecondaryBrush}"
                                               FontFamily="{StaticResource VtFontFamilyMono}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Target:"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextMutedBrush}"
                                               Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding SelectedEntry.Target}"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextSecondaryBrush}"
                                               FontFamily="{StaticResource VtFontFamilyMono}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Time:"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextMutedBrush}"
                                               Margin="0,0,8,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding SelectedEntry.FormattedTimeRange}"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextSecondaryBrush}"
                                               FontFamily="{StaticResource VtFontFamilyMono}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <ScrollViewer MaxHeight="56"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedEntry.Description}"
                                               FontSize="{StaticResource VtFontSizeSm}"
                                               Foreground="{StaticResource VtTextPrimaryBrush}"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Narrative panel -->
            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{StaticResource VtBackground800Brush}"
                    BorderBrush="{StaticResource VtBorderDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    IsVisible="{Binding IsNarrativeVisible}">
                <TextBlock Text="{Binding SelectedChainNarrative}"
                           Margin="8,6"
                           FontSize="{StaticResource VtFontSizeMd}"
                           Foreground="{StaticResource VtTextMutedBrush}"
                           TextWrapping="Wrap"
                           FontStyle="Italic"/>
            </Border>

            <!-- Accessible companion list (UI v2 Phase 4): the canvas markers are drawn in
                 code-behind and carry no automation peer, so this always-realized list exposes
                 every timeline event as a named, activatable control that selects the same
                 finding a marker click would. It is intentionally always realized (not in an
                 Expander): the harness's AT-SPI walk does not traverse Expander content, so a
                 collapsed-by-default container would hide the events from the accessibility
                 tree. The compact capped height keeps the sighted footprint small. -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="{Binding HasTimelineData}"
                    Background="{StaticResource VtBackground800Brush}"
                    BorderBrush="{StaticResource VtBorderDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8"
                    Margin="0,8,0,0">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Timeline events"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource VtTextSecondaryBrush}"
                           AutomationProperties.AutomationId="TimelineEventsHeader"
                           Margin="0,0,0,4" />
                <ScrollViewer Grid.Row="1" MaxHeight="160" VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding TimelineEntries}"
                                AutomationProperties.AutomationId="TimelineEventsList"
                                AutomationProperties.Name="Timeline events list">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:TimelineEntry">
                        <Button Command="{ReflectionBinding DataContext.SelectEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{CompiledBinding}"
                                AutomationProperties.AutomationId="{CompiledBinding EventAutomationId}"
                                AutomationProperties.Name="{CompiledBinding Converter={StaticResource TimelineEntryLabelConverter}}"
                                Theme="{StaticResource VtGhostButton}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Margin="0,2"
                                Padding="8,6">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{CompiledBinding Severity, Converter={StaticResource SeverityToBrushConverter}}" />
                            <TextBlock Text="{CompiledBinding Category, Converter={StaticResource CategoryLabelConverter}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource VtTextPrimaryBrush}" />
                            <TextBlock Text="{CompiledBinding Severity}"
                                       Foreground="{CompiledBinding Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}" />
                            <TextBlock Text="{CompiledBinding FormattedTimeRange}"
                                       FontFamily="{StaticResource VtFontFamilyMono}"
                                       Foreground="{StaticResource VtTextMutedBrush}" />
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <!-- Empty state (outside the height-constrained Canvas so it's visible when CanvasHeight=0) -->
            <controls:EmptyStateView Grid.Row="2" Grid.ColumnSpan="2"
                                     IsVisible="{Binding !HasTimelineData}"
                                     AutomationProperties.AutomationId="TimelineEmptyState"
                                     AutomationProperties.Name="Timeline empty state"
                                     Icon="mdi-chart-timeline-variant"
                                     Headline="{Binding EmptyStateHeadline}"
                                     Description="{Binding EmptyStateDescription}"
                                     ActionText="{Binding EmptyStateActionText}"
                                     ActionCommand="{Binding EmptyStateActionCommand}"
                                     ActionIcon="mdi-rocket-launch-outline"
                                     ActionAutomationId="TimelineEmptyStateAnalyzeButton"
                                     ActionAutomationName="Run audit for timeline"/>
        </Grid>
    </ScrollViewer>
</UserControl>
