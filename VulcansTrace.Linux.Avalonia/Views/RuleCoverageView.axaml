<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.RuleCoverageView"
             x:DataType="vm:RuleCoverageViewModel">

    <Design.DataContext>
        <vm:RuleCoverageViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary badges -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <Border Theme="{StaticResource VtKpiCard}" Padding="8,4">
                <TextBlock>
                    <Run Text="Total: " Foreground="{StaticResource VtTextMutedBrush}"/><Run Text="{Binding TotalRules, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                </TextBlock>
            </Border>
            <Border Theme="{StaticResource VtKpiCard}" Padding="8,4">
                <TextBlock>
                    <Run Text="Passed: " Foreground="{StaticResource VtSuccessBrush}"/><Run Text="{Binding TotalPassed, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource VtSuccessBrush}"/>
                </TextBlock>
            </Border>
            <Border Theme="{StaticResource VtKpiCard}" Background="{StaticResource VtDangerMutedBrush}" Padding="8,4" BorderBrush="{StaticResource VtDangerBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Failed: " Foreground="{StaticResource VtTextPrimaryBrush}"/><Run Text="{Binding TotalFailed, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource VtDangerBrush}"/>
                </TextBlock>
            </Border>
            <Border Theme="{StaticResource VtKpiCard}" Padding="8,4">
                <TextBlock>
                    <Run Text="Suppressed: " Foreground="{StaticResource VtTextMutedBrush}"/><Run Text="{Binding TotalSuppressed, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                </TextBlock>
            </Border>
            <Border Theme="{StaticResource VtKpiCard}" Background="{StaticResource VtWarningMutedBrush}" Padding="8,4" BorderBrush="{StaticResource VtWarningBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Crashed: " Foreground="{StaticResource VtTextPrimaryBrush}"/><Run Text="{Binding TotalCrashed, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource VtWarningBrush}"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Theme="{StaticResource VtCard}"
                Margin="0,4,0,8"
                IsVisible="{Binding !HasData}">
            <TextBlock Text="Run an agent audit to see rule coverage."
                       Foreground="{StaticResource VtTextMutedBrush}"
                       FontSize="{StaticResource VtFontSizeMd}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Category breakdown grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Categories}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"

                  CanUserResizeColumns="True"
                  IsVisible="{Binding HasData}"
                  AutomationProperties.AutomationId="CoverageDataGrid"
                  AutomationProperties.Name="Rule Coverage Table">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="180" />
                <DataGridTextColumn Header="Passed" Binding="{Binding Passed}" Width="90" />
                <DataGridTextColumn Header="Failed" Binding="{Binding Failed}" Width="90" />
                <DataGridTextColumn Header="Suppressed" Binding="{Binding Suppressed}" Width="100" />
                <DataGridTextColumn Header="Crashed" Binding="{Binding Crashed}" Width="90" />
                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
