<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="VulcansTrace.Linux.Avalonia.Views.LogDiffWindow"
        x:DataType="vm:LogDiffViewModel"
        Title="Log Diff"
        Width="1200"
        Height="640"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter">

    <Window.Resources>
        <conv:IntToBoolConverter x:Key="IntToBoolConverter" />
        <conv:LogDiffStateToBrushConverter x:Key="LogDiffStateToBrushConverter" />
        <conv:LogDiffStateToForegroundBrushConverter x:Key="LogDiffStateToForegroundBrushConverter" />
    </Window.Resources>

    <Design.DataContext>
        <vm:LogDiffViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto,*,Auto">
        <!-- Header with export actions -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="Log Comparison"
                       FontSize="{StaticResource VtFontSize2xl}"
                       FontWeight="Bold"
                       Foreground="{StaticResource VtTextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Theme="{StaticResource VtGhostButton}"
                    Padding="8,4"
                    Margin="0,0,8,0"
                    Command="{Binding ExportHtmlCommand}"
                    AutomationProperties.AutomationId="LogDiffExportHtmlButton"
                    AutomationProperties.Name="Export HTML">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <i:Icon Value="mdi-file-document-arrow-right-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                    <TextBlock Text="Export HTML" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Theme="{StaticResource VtGhostButton}"
                    Padding="8,4"
                    Command="{Binding ExportMarkdownCommand}"
                    AutomationProperties.AutomationId="LogDiffExportMarkdownButton"
                    AutomationProperties.Name="Export Markdown">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <i:Icon Value="mdi-language-markdown-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                    <TextBlock Text="Export Markdown" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Narrative -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Narrative}"
                   FontSize="{StaticResource VtFontSizeMd}"
                   Foreground="{StaticResource VtTextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Summary badges -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Added: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding AddedCount}" FontWeight="Bold" Foreground="{StaticResource VtDangerBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Removed: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding RemovedCount}" FontWeight="Bold" Foreground="{StaticResource VtSuccessBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Changed: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding ChangedCount}" FontWeight="Bold" Foreground="{StaticResource VtWarningBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Unchanged: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding UnchangedCount}" FontWeight="Bold" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Events grid -->
        <TextBlock Grid.Row="3"
                   Text="Connection Patterns"
                   FontWeight="Bold"
                   Foreground="{StaticResource VtTextSecondaryBrush}"
                   Margin="0,0,0,4"
                   IsVisible="{Binding Events.Count, Converter={StaticResource IntToBoolConverter}}"/>
        <DataGrid Grid.Row="3"
                  AutomationProperties.AutomationId="LogDiffEventsDataGrid"
                  AutomationProperties.Name="Log diff connection patterns table"
                  ItemsSource="{Binding Events}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"

                  CanUserResizeColumns="True"
                  Margin="0,20,0,0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="State" Width="130" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding State, Converter={StaticResource LogDiffStateToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding State}"
                                           Foreground="{Binding State, Converter={StaticResource LogDiffStateToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Connection" Binding="{Binding ConnectionKey}" Width="*" MinWidth="220" />
                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="100" MinWidth="90" />
                <DataGridTextColumn Header="Count Δ" Binding="{Binding CountDelta}" Width="110" MinWidth="100" />
                <DataGridTextColumn Header="Baseline" Binding="{Binding BaselineDominantAction}" Width="140" MinWidth="120" />
                <DataGridTextColumn Header="Incident" Binding="{Binding IncidentDominantAction}" Width="140" MinWidth="120" />
                <DataGridTextColumn Header="Baseline First" Binding="{Binding BaselineFirstSeen, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="210" MinWidth="200" />
                <DataGridTextColumn Header="Incident First" Binding="{Binding IncidentFirstSeen, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="210" MinWidth="200" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state for events -->
        <TextBlock Grid.Row="3"
                   Text="No connection patterns to display."
                   Foreground="{StaticResource VtTextMutedBrush}"
                   FontSize="{StaticResource VtFontSizeMd}"
                   IsVisible="{Binding !Events.Count, Converter={StaticResource IntToBoolConverter}}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

        <!-- Findings label -->
        <TextBlock Grid.Row="4"
                   Text="Findings"
                   FontWeight="Bold"
                   Foreground="{StaticResource VtTextSecondaryBrush}"
                   Margin="0,12,0,4"
                   IsVisible="{Binding Findings.Count, Converter={StaticResource IntToBoolConverter}}"/>

        <!-- Findings grid -->
        <DataGrid Grid.Row="5"
                  AutomationProperties.AutomationId="LogDiffFindingsDataGrid"
                  AutomationProperties.Name="Log diff findings table"
                  ItemsSource="{Binding Findings}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"

                  CanUserResizeColumns="True"
                  IsVisible="{Binding Findings.Count, Converter={StaticResource IntToBoolConverter}}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="State" Width="130" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding State, Converter={StaticResource LogDiffStateToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding State}"
                                           Foreground="{Binding State, Converter={StaticResource LogDiffStateToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Category" Binding="{Binding Finding.Category, Converter={StaticResource CategoryLabelConverter}}" Width="150" MinWidth="130" />
                <DataGridTextColumn Header="Severity" Binding="{Binding Finding.Severity}" Width="130" MinWidth="120" />
                <DataGridTextColumn Header="Source" Binding="{Binding Finding.SourceHost}" Width="140" MinWidth="130" />
                <DataGridTextColumn Header="Target" Binding="{Binding Finding.Target}" Width="150" MinWidth="120" />
                <DataGridTextColumn Header="Description" Binding="{Binding Finding.ShortDescription}" Width="*" MinWidth="180" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status message -->
        <TextBlock Grid.Row="6"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource VtTextMutedBrush}"
                   FontSize="{StaticResource VtFontSizeSm}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   IsVisible="{Binding HasStatusMessage}"
                   AutomationProperties.AutomationId="LogDiffStatusMessage"
                   AutomationProperties.Name="Log diff status"/>
    </Grid>
</Window>
