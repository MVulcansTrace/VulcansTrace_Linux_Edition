<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             x:Class="VulcansTrace.Linux.Avalonia.Views.RiskScorecardView"
             x:DataType="vm:RiskScorecardViewModel">

    <Design.DataContext>
        <vm:RiskScorecardViewModel/>
    </Design.DataContext>

    <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,*">
        <!-- Overall grade -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16" IsVisible="{Binding HasData}">
            <Border Background="{Binding GradeBackground}"
                    BorderBrush="{Binding GradeColor}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="24,16">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding LetterGrade}"
                               FontSize="{StaticResource VtIconSize3xl}"
                               FontWeight="Bold"
                               Foreground="{Binding GradeColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding NumericScore, StringFormat={}{0:F1}}"
                               FontSize="{StaticResource VtFontSizeSm}"
                               FontWeight="SemiBold"
                               Foreground="{Binding GradeColor}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="Risk Score"
                           FontSize="{StaticResource VtFontSize2xl}"
                           FontWeight="Bold"
                           Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <TextBlock Text="Weighted by severity and CIS control importance"
                           FontSize="{StaticResource VtFontSizeMd}"
                           Foreground="{StaticResource VtTextSecondaryBrush}"/>
                <TextBlock Text="{Binding SummaryStatus}"
                           FontSize="{StaticResource VtFontSizeXs}"
                           Foreground="{Binding GradeColor}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalDeduction, StringFormat='Total deduction: {0:F1} (score floored at 0)'}"
                           FontSize="{StaticResource VtFontSizeXs}"
                           Foreground="{StaticResource VtTextMutedBrush}"
                           IsVisible="{Binding IsSaturated}"
                           TextWrapping="Wrap"
                           MaxWidth="420"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Empty state -->
        <controls:EmptyStateView Grid.Row="0"
                                 Grid.RowSpan="4"
                                 Icon="mdi-alert-decagram"
                                 Headline="No risk scorecard yet"
                                 Description="Run an analysis to calculate a weighted risk grade and category breakdown."
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="RiskEmptyStateAnalyzeButton"
                                 ActionAutomationName="Run audit for risk scorecard"
                                 IsVisible="{Binding !HasData}"/>

        <!-- Category breakdown -->
        <TextBlock Grid.Row="2"
                   Text="Risk by Category"
                   FontWeight="Bold"
                   FontSize="{StaticResource VtFontSizeXl}"
                   Foreground="{StaticResource VtTextPrimaryBrush}"
                   Margin="0,0,0,8"
                   IsVisible="{Binding HasData}"/>

        <DataGrid Grid.Row="3"
                  AutomationProperties.AutomationId="RiskCategoryDataGrid"
                  AutomationProperties.Name="Risk by category table"
                  ItemsSource="{Binding ByCategory}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"

                  CanUserResizeColumns="True"
                  IsVisible="{Binding HasData}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category, Converter={StaticResource CategoryLabelConverter}}" Width="*" MinWidth="220" />
                <DataGridTextColumn Header="Findings" Binding="{Binding FindingCount}" Width="130" MinWidth="120" />
                <DataGridTextColumn Header="Avg Severity" Binding="{Binding AverageSeverity, StringFormat={}{0:F1}}" Width="155" MinWidth="140" />
                <DataGridTextColumn Header="Deduction" Binding="{Binding TotalDeduction, StringFormat={}{0:F1}}" Width="135" MinWidth="125" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
