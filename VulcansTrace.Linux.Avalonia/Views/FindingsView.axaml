<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="VulcansTrace.Linux.Avalonia.Views.FindingsView"
             x:DataType="vm:FindingsViewModel"
             Focusable="True"
             ToolTip.Tip="Findings (Ctrl+P to pin/unpin selected)">

    <Design.DataContext>
        <vm:FindingsViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Search:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                <TextBox Text="{Binding SearchText}"
                         Width="220"
                         VerticalAlignment="Center"
                         Theme="{StaticResource VtInput}"
                         PlaceholderText="Search findings..."
                         AutomationProperties.AutomationId="SearchTextBox"/>
                <TextBlock Text="Severity filter:" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                <ComboBox ItemsSource="{Binding SeverityFilters}"
                          SelectedItem="{Binding SelectedSeverityFilter}"
                          Width="180"
                          VerticalAlignment="Center"
                          Theme="{StaticResource VtComboBox}"
                          AutomationProperties.AutomationId="SeverityFilterComboBox"/>
                <Button Theme="{StaticResource VtGhostButton}"
                        Padding="8,4"
                        FontSize="{StaticResource VtFontSizeSm}"
                        ToolTip.Tip="Show only pinned findings"
                        Command="{Binding TogglePinnedOnlyCommand}"
                        AutomationProperties.AutomationId="FindingsPinnedOnlyButton">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <i:Icon Value="mdi-pin" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="Pinned only" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PinnedCountLabel}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource VtTextMutedBrush}"
                                   IsVisible="{Binding HasPinnedFindings}"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding PinStatusMessage}"
                           MaxWidth="360"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding PinStatusMessage}"
                           Foreground="{StaticResource VtSeverityMediumBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding HasPinStatusMessage}"
                           AutomationProperties.AutomationId="FindingsPinStatusMessage"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,8,0,0" HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedFindingActionContext}"
                           MaxWidth="400"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding SelectedFindingActionContext}"
                           Foreground="{StaticResource VtTextMutedBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           AutomationProperties.AutomationId="FindingsSelectedActionContext"/>
                <Button Theme="{StaticResource VtGhostButton}"
                        Padding="8,4"
                        FontSize="{StaticResource VtFontSizeSm}"
                        ToolTip.Tip="Investigate with Security Agent"
                        Command="{Binding InvestigateCommand}"
                        CommandParameter="{Binding SelectedItem}"
                        AutomationProperties.AutomationId="FindingsInvestigateButton">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <i:Icon Value="mdi-magnify" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="Investigate" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Theme="{StaticResource VtGhostButton}"
                        Padding="8,4"
                        FontSize="{StaticResource VtFontSizeSm}"
                        ToolTip.Tip="Suppress (accept risk)"
                        Command="{Binding SuppressCommand}"
                        CommandParameter="{Binding SelectedItem}"
                        AutomationProperties.AutomationId="FindingsSuppressButton">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <i:Icon Value="mdi-volume-off" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="Suppress" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Theme="{StaticResource VtGhostButton}"
                        Padding="8,4"
                        FontSize="{StaticResource VtFontSizeSm}"
                        ToolTip.Tip="Generate remediation plan"
                        Command="{Binding ResolveCommand}"
                        CommandParameter="{Binding SelectedItem}"
                        AutomationProperties.AutomationId="FindingsResolveButton">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <i:Icon Value="mdi-shield-check-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="Resolve" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Theme="{StaticResource VtGhostButton}"
                        Padding="8,4"
                        FontSize="{StaticResource VtFontSizeSm}"
                        ToolTip.Tip="Re-run the rule to verify remediation"
                        Command="{Binding VerifyFindingCommand}"
                        CommandParameter="{Binding SelectedItem}"
                        AutomationProperties.AutomationId="FindingsVerifyButton"
                        AutomationProperties.Name="Verify">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <i:Icon Value="mdi-check-circle-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                        <TextBlock Text="Verify" FontSize="{StaticResource VtFontSizeSm}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="FindingsDataGrid" Grid.Row="1"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  HorizontalScrollBarVisibility="Auto"
                  IsVisible="{Binding HasData}"
                  Focusable="True"
                  AutomationProperties.AutomationId="FindingsDataGrid"
                  AutomationProperties.Name="Findings Table">
            <DataGrid.Styles>
                <Style Selector="DataGridCell TextBlock">
                    <Setter Property="ToolTip.Tip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="Auto" CanUserResize="False" CanUserReorder="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Theme="{StaticResource VtGhostButton}"
                                        Padding="6,2"
                                        ToolTip.Tip="{Binding PinTooltip}"
                                        Command="{Binding #FindingsDataGrid.DataContext.PinCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding !IsPinned}"
                                        AutomationProperties.AutomationId="FindingsPinButton">
                                    <i:Icon Value="mdi-pin-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Theme="{StaticResource VtGhostButton}"
                                        Padding="6,2"
                                        ToolTip.Tip="{Binding PinTooltip}"
                                        Command="{Binding #FindingsDataGrid.DataContext.UnpinCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding IsPinned}"
                                        AutomationProperties.AutomationId="FindingsUnpinButton">
                                    <i:Icon Value="mdi-pin-off" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                                </Button>
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Severity" Width="90" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding Severity}"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Count" Binding="{Binding GroupedCount}" Width="Auto" MinWidth="70" CanUserResize="True"/>
                <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="Auto" MinWidth="80" CanUserResize="True"/>
                <DataGridTextColumn Header="Evidence Signals" Binding="{Binding EvidenceSignalsDisplay}" Width="*" MinWidth="120" CanUserResize="True"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" MinWidth="90" CanUserResize="True"/>
                <DataGridTextColumn Header="Source" Binding="{Binding SourceHost}" Width="Auto" MinWidth="90" CanUserResize="True"/>
                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="Auto" MinWidth="90" CanUserResize="True"/>
                <DataGridTextColumn Header="Time" Binding="{Binding TimeRangeDisplay}" Width="Auto" MinWidth="110" CanUserResize="True"/>
                <DataGridTextColumn Header="MITRE ATT&amp;CK" Binding="{Binding MitreTechniquesDisplay}" Width="Auto" MinWidth="120" CanUserResize="True"/>
                <DataGridTextColumn Header="Description" Binding="{Binding ShortDescription}" Width="*" MinWidth="140" CanUserResize="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Filter excluded everything: show a targeted hint instead of the never-analyzed empty state -->
        <controls:FilterEmptyStateView Grid.Row="1"
                                       IsVisible="{Binding HasNoFilterMatches}"
                                       Icon="mdi-filter-remove-outline"
                                       Headline="No findings match your filter"
                                       Description="Adjust the search box or severity filter to widen the results."/>

        <controls:EmptyStateView Grid.Row="1"
                                 Icon="mdi-magnify"
                                 Headline="{Binding EmptyStateHeadline}"
                                 Description="{Binding EmptyStateDescription}"
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="FindingsEmptyStateAnalyzeButton"
                                 IsVisible="{Binding !HasItems}"/>
    </Grid>
</UserControl>
