<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="VulcansTrace.Linux.Avalonia.Views.FindingsView"
             x:DataType="vm:FindingsViewModel">

    <Design.DataContext>
        <vm:FindingsViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <TextBox Text="{Binding SearchText}"
                     Width="220"
                     VerticalAlignment="Center"
                     Theme="{StaticResource VtInput}"
                     Watermark="Search findings..."
                     AutomationProperties.AutomationId="SearchTextBox"/>
            <TextBlock Text="Severity filter:" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <ComboBox ItemsSource="{Binding SeverityFilters}"
                      SelectedItem="{Binding SelectedSeverityFilter}"
                      Width="180"
                      VerticalAlignment="Center"
                      Theme="{StaticResource VtComboBox}"
                      AutomationProperties.AutomationId="SeverityFilterComboBox"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <Button Content="Accept Risk"
                    Theme="{StaticResource VtSecondaryButton}"
                    Margin="0,0,8,6"
                    ToolTip.Tip="Mark the selected finding as accepted/expected"
                    Command="{Binding AcceptRiskCommand}"
                    AutomationProperties.AutomationId="FindingsAcceptRiskButton"/>
            <TextBlock Text="Select a finding to accept or remediate risk."
                       VerticalAlignment="Center"
                       Foreground="{StaticResource VtTextMutedBrush}"
                       FontSize="{StaticResource VtFontSizeSm}"
                       Margin="0,0,0,6"/>
        </WrapPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  HorizontalScrollBarVisibility="Auto"
                  IsVisible="{Binding HasData}"
                  AutomationProperties.AutomationId="FindingsDataGrid"
                  AutomationProperties.Name="Findings Table">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Severity" Width="Auto" MinWidth="90" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding Severity}"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Count" Width="Auto" MinWidth="70" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding GroupedCount}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource VtTextPrimaryBrush}"
                                       FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Confidence" Width="Auto" MinWidth="100" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Confidence}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Evidence Signals" Width="Auto" MinWidth="240" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding EvidenceSignalsDisplay}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding EvidenceSignalsDisplay}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Category" Width="Auto" MinWidth="120" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Category}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Category}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Source" Width="Auto" MinWidth="110" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding SourceHost}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SourceHost}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Target" Width="Auto" MinWidth="110" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Target}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="From" Width="Auto" MinWidth="130" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding TimeStart, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="To" Width="Auto" MinWidth="130" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding TimeEnd, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="MITRE ATT&amp;CK" Width="Auto" MinWidth="160" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding MitreTechniquesDisplay}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding MitreTechniquesDisplay}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Description" Width="Auto" MinWidth="300" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding ShortDescription}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ShortDescription}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Filter excluded everything: show a targeted hint instead of the never-analyzed empty state -->
        <controls:FilterEmptyStateView Grid.Row="2"
                                       IsVisible="{Binding HasNoFilterMatches}"
                                       Icon="mdi-filter-remove-outline"
                                       Headline="No findings match your filter"
                                       Description="Adjust the search box or severity filter to widen the results."/>

        <controls:EmptyStateView Grid.Row="2"
                                 Icon="mdi-magnify"
                                 Headline="{Binding EmptyStateHeadline}"
                                 Description="{Binding EmptyStateDescription}"
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="FindingsEmptyStateAnalyzeButton"
                                 IsVisible="{Binding !HasItems}"/>
    </Grid>
</UserControl>
