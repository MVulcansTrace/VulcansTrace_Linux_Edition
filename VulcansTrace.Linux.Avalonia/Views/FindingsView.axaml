<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.FindingsView"
             x:DataType="vm:FindingsViewModel">

    <Design.DataContext>
        <vm:FindingsViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <TextBox Text="{Binding SearchText}"
                     Width="220"
                     VerticalAlignment="Center"
                     Theme="{StaticResource VtInput}"
                     AutomationProperties.AutomationId="SearchTextBox"/>
            <TextBlock Text="Severity filter:" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <ComboBox ItemsSource="{Binding SeverityFilters}"
                      SelectedItem="{Binding SelectedSeverityFilter}"
                      Width="180"
                      VerticalAlignment="Center"
                      Theme="{StaticResource VtComboBox}"
                      AutomationProperties.AutomationId="SeverityFilterComboBox"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  AutomationProperties.AutomationId="FindingsDataGrid"
                  AutomationProperties.Name="Findings Table">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Severity" Width="80" MinWidth="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding Severity}"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Count" Binding="{Binding GroupBadge}" Width="100" MinWidth="100" />
                <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="120" MinWidth="120" />
                <DataGridTextColumn Header="Evidence Signals" Binding="{Binding EvidenceSignalsDisplay}" Width="360" MinWidth="240" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160" MinWidth="160" />
                <DataGridTextColumn Header="Source" Binding="{Binding SourceHost}" Width="200" />
                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="220" />
                <DataGridTextColumn Header="From" Binding="{Binding TimeStart, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="150" />
                <DataGridTextColumn Header="To" Binding="{Binding TimeEnd, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="150" />
                <DataGridTextColumn Header="MITRE ATT&amp;CK" Binding="{Binding MitreTechniquesDisplay}" Width="150" />
                <DataGridTextColumn Header="Description" Binding="{Binding ShortDescription}" Width="340" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
