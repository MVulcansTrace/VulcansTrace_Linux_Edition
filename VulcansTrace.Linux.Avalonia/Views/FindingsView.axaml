<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="VulcansTrace.Linux.Avalonia.Views.FindingsView"
             x:DataType="vm:FindingsViewModel">

    <Design.DataContext>
        <vm:FindingsViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <TextBox Text="{Binding SearchText}"
                     Width="220"
                     VerticalAlignment="Center"
                     Theme="{StaticResource VtInput}"
                     Watermark="Search findings..."
                     AutomationProperties.AutomationId="SearchTextBox"/>
            <TextBlock Text="Severity filter:" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <ComboBox ItemsSource="{Binding SeverityFilters}"
                      SelectedItem="{Binding SelectedSeverityFilter}"
                      Width="180"
                      VerticalAlignment="Center"
                      Theme="{StaticResource VtComboBox}"
                      AutomationProperties.AutomationId="SeverityFilterComboBox"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="False"
                  HorizontalScrollBarVisibility="Auto"
                  IsVisible="{Binding HasData}"
                  AutomationProperties.AutomationId="FindingsDataGrid"
                  AutomationProperties.Name="Findings Table">
            <DataGrid.Styles>
                <Style Selector="DataGridRow StackPanel.actionsPanel">
                    <Setter Property="IsVisible" Value="False"/>
                </Style>
                <Style Selector="DataGridRow:pointerover StackPanel.actionsPanel">
                    <Setter Property="IsVisible" Value="True"/>
                </Style>
                <Style Selector="DataGridRow:selected StackPanel.actionsPanel">
                    <Setter Property="IsVisible" Value="True"/>
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Severity" Width="90" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                                <TextBlock Text="{Binding Severity}"
                                           Foreground="{StaticResource VtTextPrimaryBrush}"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Count" Width="Auto" MinWidth="70" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding GroupedCount}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource VtTextPrimaryBrush}"
                                       FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Confidence" Width="Auto" MinWidth="80" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Confidence}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Evidence Signals" Width="*" MinWidth="120" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding EvidenceSignalsDisplay}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding EvidenceSignalsDisplay}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Category" Width="Auto" MinWidth="90" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Category}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Category}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Source" Width="Auto" MinWidth="90" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding SourceHost}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SourceHost}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Target" Width="Auto" MinWidth="90" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Target}" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Time" Width="Auto" MinWidth="110" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding TimeRangeDisplay}"
                                       ToolTip.Tip="{Binding TimeRangeDisplay}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="MITRE ATT&amp;CK" Width="Auto" MinWidth="120" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding MitreTechniquesDisplay}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding MitreTechniquesDisplay}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Description" Width="*" MinWidth="140" CanUserResize="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <TextBlock Text="{Binding ShortDescription}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ShortDescription}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="Auto" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:FindingItemViewModel">
                            <StackPanel Classes="actionsPanel" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <Button Theme="{StaticResource VtGhostButton}"
                                        Padding="6,2"
                                        FontSize="{StaticResource VtFontSizeSm}"
                                        ToolTip.Tip="Investigate"
                                        Command="{Binding DataContext.InvestigateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}, x:CompileBindings=False}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.AutomationId="FindingsInvestigateButton">
                                    <i:Icon Value="mdi-magnify" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Theme="{StaticResource VtGhostButton}"
                                        Padding="6,2"
                                        FontSize="{StaticResource VtFontSizeSm}"
                                        ToolTip.Tip="Suppress"
                                        Command="{Binding DataContext.SuppressCommand, RelativeSource={RelativeSource AncestorType=DataGrid}, x:CompileBindings=False}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.AutomationId="FindingsSuppressButton">
                                    <i:Icon Value="mdi-volume-off" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Theme="{StaticResource VtGhostButton}"
                                        Padding="6,2"
                                        FontSize="{StaticResource VtFontSizeSm}"
                                        ToolTip.Tip="Resolve"
                                        Command="{Binding DataContext.ResolveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}, x:CompileBindings=False}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.AutomationId="FindingsResolveButton">
                                    <i:Icon Value="mdi-shield-check-outline" FontSize="{StaticResource VtIconSizeSm}" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Filter excluded everything: show a targeted hint instead of the never-analyzed empty state -->
        <controls:FilterEmptyStateView Grid.Row="1"
                                       IsVisible="{Binding HasNoFilterMatches}"
                                       Icon="mdi-filter-remove-outline"
                                       Headline="No findings match your filter"
                                       Description="Adjust the search box or severity filter to widen the results."/>

        <controls:EmptyStateView Grid.Row="1"
                                 Icon="mdi-magnify"
                                 Headline="{Binding EmptyStateHeadline}"
                                 Description="{Binding EmptyStateDescription}"
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="FindingsEmptyStateAnalyzeButton"
                                 IsVisible="{Binding !HasItems}"/>
    </Grid>
</UserControl>
