<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        x:Class="VulcansTrace.Linux.Avalonia.Views.RemediationPreviewWindow"
        x:DataType="vm:RemediationPreviewViewModel"
        Title="Remediation Preview"
        Width="720"
        Height="560"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Text="Review remediation plan before executing" FontWeight="Bold" FontSize="{StaticResource VtFontSize2xl}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,8"/>

        <Border Grid.Row="1" Theme="{StaticResource VtCard}" Padding="12" Margin="0,0,0,12">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Summary}" Foreground="{StaticResource VtTextPrimaryBrush}" TextWrapping="Wrap" FontFamily="{StaticResource VtFontFamily}"/>
                <TextBlock Text="This will change system configuration. Review carefully before confirming." Foreground="{StaticResource VtDangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Background="{StaticResource VtBackground900Brush}" CornerRadius="{StaticResource VtRadiusLg}" Padding="12">
            <TextBlock Text="{Binding PreviewText}" Foreground="{StaticResource VtTextSecondaryBrush}" FontFamily="{StaticResource VtFontFamilyMono}" TextWrapping="Wrap"/>
        </ScrollViewer>

        <!-- Execution result, shown only after the plan has run (dialog stays open so it's visible). -->
        <Border Grid.Row="3" Background="{StaticResource VtBackground900Brush}" CornerRadius="{StaticResource VtRadiusLg}" Padding="12" Margin="0,8,0,0" IsVisible="{Binding HasResult}">
            <TextBlock Text="{Binding ExecutionResult.Summary}" Foreground="{StaticResource VtTextSecondaryBrush}" FontFamily="{StaticResource VtFontFamilyMono}" TextWrapping="Wrap"/>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="{StaticResource VtWarningBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="ExecuteButton" Content="Execute" MinWidth="100" Theme="{StaticResource VtPrimaryButton}" Command="{Binding ExecuteCommand}"/>
            <Button x:Name="CloseButton" Content="Close" MinWidth="100" Theme="{StaticResource VtSecondaryButton}" Click="CloseButton_Click" IsEnabled="{Binding !IsExecuting}"/>
        </StackPanel>
    </Grid>
</Window>
