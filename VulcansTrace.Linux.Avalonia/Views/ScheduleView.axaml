<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="VulcansTrace.Linux.Avalonia.Views.ScheduleView"
             x:DataType="vm:ScheduleViewModel">

    <Design.DataContext>
        <vm:ScheduleViewModel/>
    </Design.DataContext>

    <Grid Margin="8" RowDefinitions="Auto,Auto,*">
        <!-- Toolbar: grouped by concern-class (CRUD / state / run / cron / output)
             with VtToolbarSeparator dividers so each cluster is scannable. -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <!-- Create / edit / delete -->
            <Button Content="Add" AutomationProperties.AutomationId="ScheduleAddButton" AutomationProperties.Name="Add schedule" Command="{Binding AddCommand}" Theme="{StaticResource VtPrimaryButton}" MinWidth="60" Margin="0,0,6,6"/>
            <Button Content="Edit" AutomationProperties.AutomationId="ScheduleEditButton" AutomationProperties.Name="Edit schedule" Command="{Binding EditCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="60" Margin="0,0,6,6"/>
            <Button Content="Delete" AutomationProperties.AutomationId="ScheduleDeleteButton" AutomationProperties.Name="Delete schedule" Command="{Binding DeleteCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="60" Margin="0,0,6,6"/>
            <Border Theme="{StaticResource VtToolbarSeparator}"/>
            <!-- Enable / disable state -->
            <Button Content="Enable" AutomationProperties.AutomationId="ScheduleEnableButton" AutomationProperties.Name="Enable schedule" Command="{Binding EnableCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="60" Margin="0,0,6,6"/>
            <Button Content="Disable" AutomationProperties.AutomationId="ScheduleDisableButton" AutomationProperties.Name="Disable schedule" Command="{Binding DisableCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="60" Margin="0,0,6,6"/>
            <Border Theme="{StaticResource VtToolbarSeparator}"/>
            <!-- Immediate execution -->
            <Button Content="Run Now" AutomationProperties.AutomationId="ScheduleRunNowButton" AutomationProperties.Name="Run schedule now" Command="{Binding RunNowCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="70" Margin="0,0,6,6"/>
            <Border Theme="{StaticResource VtToolbarSeparator}"/>
            <!-- System cron integration -->
            <Button Content="Install Cron" AutomationProperties.AutomationId="ScheduleInstallCronButton" AutomationProperties.Name="Install schedule cron job" Command="{Binding InstallCronCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="80" Margin="0,0,6,6"/>
            <Button Content="Uninstall Cron" AutomationProperties.AutomationId="ScheduleUninstallCronButton" AutomationProperties.Name="Uninstall schedule cron job" Command="{Binding UninstallCronCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="90" Margin="0,0,6,6"/>
            <Border Theme="{StaticResource VtToolbarSeparator}"/>
            <!-- Post-run output and remediation -->
            <Button Content="Open Output" AutomationProperties.AutomationId="ScheduleOpenOutputButton" AutomationProperties.Name="Open schedule output" Command="{Binding OpenOutputCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="80" Margin="0,0,6,6"/>
            <Button Content="Remediate" AutomationProperties.AutomationId="ScheduleRemediateButton" AutomationProperties.Name="Remediate schedule finding" Command="{Binding RemediateCommand}" Theme="{StaticResource VtSecondaryButton}" MinWidth="80" Margin="0,0,6,6"/>
        </WrapPanel>

        <!-- Status / selection hint (single computed line, mirrors FindingsView's
             SelectedFindingActionContext). A direct Grid child so TextWrapping engages;
             StatusMessage wins, else the hint shows only when a row could be selected. -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusOrHint}"
                   Foreground="{StaticResource VtTextMutedBrush}"
                   FontSize="{StaticResource VtFontSizeSm}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   AutomationProperties.AutomationId="ScheduleStatusOrHint"
                   AutomationProperties.Name="Schedule status or selection hint"/>

        <!-- Schedule list -->
        <DataGrid Grid.Row="2"
                  AutomationProperties.AutomationId="SchedulesDataGrid"
                  AutomationProperties.Name="Schedules table"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  IsVisible="{Binding HasRows}"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" MinWidth="130" />
                <DataGridTextColumn Header="Intent" Binding="{Binding Intent}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Role" Binding="{Binding MachineRole}" Width="100" MinWidth="90" />
                <DataGridTextColumn Header="Cron" Binding="{Binding CronExpression}" Width="120" MinWidth="110" />
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="56" MinWidth="48" CanUserResize="False">
                    <DataGridCheckBoxColumn.HeaderTemplate>
                        <DataTemplate>
                            <i:Icon Value="mdi-toggle-switch" FontSize="{StaticResource VtIconSizeSm}" AutomationProperties.Name="Enabled" />
                        </DataTemplate>
                    </DataGridCheckBoxColumn.HeaderTemplate>
                </DataGridCheckBoxColumn>
                <DataGridCheckBoxColumn Header="Notify on critical" Binding="{Binding NotifyOnCritical}" Width="56" MinWidth="48" CanUserResize="False">
                    <DataGridCheckBoxColumn.HeaderTemplate>
                        <DataTemplate>
                            <i:Icon Value="mdi-bell-outline" FontSize="{StaticResource VtIconSizeSm}" AutomationProperties.Name="Notify on critical" />
                        </DataTemplate>
                    </DataGridCheckBoxColumn.HeaderTemplate>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Channel" Binding="{Binding NotificationChannel}" Width="120" MinWidth="110" />
                <DataGridCheckBoxColumn Header="Autonomous drift response" Binding="{Binding AutonomousDriftResponse}" Width="56" MinWidth="48" CanUserResize="False">
                    <DataGridCheckBoxColumn.HeaderTemplate>
                        <DataTemplate>
                            <i:Icon Value="mdi-swap-horizontal" FontSize="{StaticResource VtIconSizeSm}" AutomationProperties.Name="Autonomous drift response" />
                        </DataTemplate>
                    </DataGridCheckBoxColumn.HeaderTemplate>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Threshold" Binding="{Binding AutonomousDriftSeverityThreshold}" Width="135" MinWidth="125" />
                <DataGridCheckBoxColumn Header="Allow auto-remediate" Binding="{Binding AllowAutoRemediate}" Width="56" MinWidth="48" CanUserResize="False">
                    <DataGridCheckBoxColumn.HeaderTemplate>
                        <DataTemplate>
                            <i:Icon Value="mdi-wrench-outline" FontSize="{StaticResource VtIconSizeSm}" AutomationProperties.Name="Allow auto-remediate" />
                        </DataTemplate>
                    </DataGridCheckBoxColumn.HeaderTemplate>
                </DataGridCheckBoxColumn>
                <DataGridCheckBoxColumn Header="Installed in cron" Binding="{Binding IsInstalledInCron}" Width="56" MinWidth="48" CanUserResize="False">
                    <DataGridCheckBoxColumn.HeaderTemplate>
                        <DataTemplate>
                            <i:Icon Value="mdi-clock-outline" FontSize="{StaticResource VtIconSizeSm}" AutomationProperties.Name="Installed in cron" />
                        </DataTemplate>
                    </DataGridCheckBoxColumn.HeaderTemplate>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="195" MinWidth="185" />
                <DataGridTextColumn Header="Output Dir" Binding="{Binding OutputDirectory}" Width="*" MinWidth="180" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state: no schedules configured yet. Teaches what a schedule is
             and offers the Add action so a user (or the agent) has an obvious next step. -->
        <controls:EmptyStateView Grid.Row="2"
                                 AutomationProperties.AutomationId="SchedulesEmptyState"
                                 AutomationProperties.Name="Schedules empty state"
                                 Icon="mdi-clock-outline"
                                 Headline="No schedules yet"
                                 Description="Schedules run audits automatically on a cron interval so drift is caught without manual effort. Add one to pick an intent, machine role, cron expression, and optional critical-severity notifications."
                                 ActionText="Add schedule"
                                 ActionIcon="mdi-plus"
                                 ActionCommand="{Binding AddCommand}"
                                 ActionAutomationId="SchedulesEmptyStateAddButton"
                                 ActionAutomationName="Add schedule from empty state"
                                 IsVisible="{Binding !HasRows}"/>
    </Grid>
</UserControl>
