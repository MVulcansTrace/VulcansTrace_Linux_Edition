<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.ScheduleView"
             x:DataType="vm:ScheduleViewModel">

    <Design.DataContext>
        <vm:ScheduleViewModel/>
    </Design.DataContext>

    <Grid Margin="8" RowDefinitions="Auto,Auto,*">
        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
            <Button Content="Add" Command="{Binding AddCommand}" MinWidth="60"/>
            <Button Content="Edit" Command="{Binding EditCommand}" MinWidth="60"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}" MinWidth="60"/>
            <Button Content="Enable" Command="{Binding EnableCommand}" MinWidth="60"/>
            <Button Content="Disable" Command="{Binding DisableCommand}" MinWidth="60"/>
            <Button Content="Run Now" Command="{Binding RunNowCommand}" MinWidth="70"/>
            <Button Content="Install Cron" Command="{Binding InstallCronCommand}" MinWidth="80"/>
            <Button Content="Uninstall Cron" Command="{Binding UninstallCronCommand}" MinWidth="90"/>
            <Button Content="Open Output" Command="{Binding OpenOutputCommand}" MinWidth="80"/>
            <Button Content="Remediate" Command="{Binding RemediateCommand}" MinWidth="80"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   Foreground="#94a3b8"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <!-- Schedule list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140" />
                <DataGridTextColumn Header="Intent" Binding="{Binding Intent}" Width="110" />
                <DataGridTextColumn Header="Role" Binding="{Binding MachineRole}" Width="90" />
                <DataGridTextColumn Header="Cron" Binding="{Binding CronExpression}" Width="100" />
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="65" />
                <DataGridCheckBoxColumn Header="Notify" Binding="{Binding NotifyOnCritical}" Width="55" />
                <DataGridTextColumn Header="Channel" Binding="{Binding NotificationChannel}" Width="70" />
                <DataGridCheckBoxColumn Header="Drift" Binding="{Binding AutonomousDriftResponse}" Width="50" />
                <DataGridTextColumn Header="Threshold" Binding="{Binding AutonomousDriftSeverityThreshold}" Width="70" />
                <DataGridCheckBoxColumn Header="Rmdt" Binding="{Binding AllowAutoRemediate}" Width="50" />
                <DataGridCheckBoxColumn Header="Cron?" Binding="{Binding IsInstalledInCron}" Width="50" />
                <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="120" />
                <DataGridTextColumn Header="Output Dir" Binding="{Binding OutputDirectory}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
