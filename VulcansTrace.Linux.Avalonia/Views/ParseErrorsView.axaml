<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             x:Class="VulcansTrace.Linux.Avalonia.Views.ParseErrorsView"
             x:DataType="vm:FindingsViewModel">

    <Design.DataContext>
        <vm:FindingsViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Parse Errors"
                   Foreground="{StaticResource VtDangerBrush}"
                   FontWeight="Bold"
                   FontSize="{StaticResource VtFontSizeXl}"
                   Margin="0,0,0,8"/>

        <ListBox Grid.Row="1"
                 AutomationProperties.AutomationId="ParseErrorsList"
                 AutomationProperties.Name="Parse errors"
                 ItemsSource="{Binding ParseErrors}"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="{StaticResource VtDangerBrush}"
                 FontFamily="{StaticResource VtFontFamilyMono}"
                 IsVisible="{Binding HasParseErrors}"/>

        <controls:EmptyStateView Grid.Row="1"
                                 Icon="mdi-alert-circle"
                                 Headline="No parse errors"
                                 Description="Log lines that could not be parsed will appear here. Check your log format if errors show up."
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="ParseErrorsEmptyStateAnalyzeButton"
                                 ActionAutomationName="Analyze input from parse errors"
                                 IsVisible="{Binding !HasParseErrors}"/>
    </Grid>
</UserControl>
