<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             x:Class="VulcansTrace.Linux.Avalonia.Views.SuppressionView"
             x:DataType="vm:SuppressionViewModel">

    <Design.DataContext>
        <vm:SuppressionViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Active suppressions (moved from the old main-window left column;
             the DataContext is the same SuppressionViewModel) -->
        <Expander Grid.Row="0"
                  Header="Active Suppressions"
                  IsExpanded="True"
                  Theme="{StaticResource VtExpander}"
                  AutomationProperties.AutomationId="ActiveSuppressionsExpander"
                  AutomationProperties.Name="Active suppressions"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="No active suppressions."
                           IsVisible="{Binding IsEmpty}"
                           Foreground="{StaticResource VtTextMutedBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           Margin="0,4,0,4"/>
                <ItemsControl ItemsSource="{Binding Entries}" MaxHeight="160"
                              AutomationProperties.AutomationId="ActiveSuppressionsList"
                              AutomationProperties.Name="Active suppressions"
                              IsVisible="{Binding !IsEmpty}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding RuleId}"
                                           Foreground="{StaticResource VtTextPrimaryBrush}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Target}"
                                           Foreground="{StaticResource VtTextSecondaryBrush}"
                                           FontSize="{StaticResource VtFontSizeSm}"
                                           Margin="8,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Reason}"
                                           Foreground="{StaticResource VtTextMutedBrush}"
                                           FontSize="{StaticResource VtFontSizeXs}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="120"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3"
                                        Content="Remove"
                                        AutomationProperties.AutomationId="ActiveSuppressionRemoveButton"
                                        AutomationProperties.Name="Remove active suppression"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[ItemsControl].DataContext.RemoveSuppressionCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding StatusMessage}"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           AutomationProperties.AutomationId="ActiveSuppressionsStatusMessage"
                           AutomationProperties.Name="Active suppressions status"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource VtTextSecondaryBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Expander>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <ComboBox ItemsSource="{Binding ReviewFilters}"
                      SelectedItem="{Binding SelectedReviewFilter}"
                      Width="220"
                      VerticalAlignment="Center"
                      Theme="{StaticResource VtComboBox}"
                      AutomationProperties.AutomationId="SuppressionsFilterComboBox"
                      AutomationProperties.Name="Suppressions review filter">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ReviewFilterLabelConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding ReviewQueueCount, StringFormat='{}Items: {0}'}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="{StaticResource VtTextMutedBrush}"/>
        </StackPanel>

        <!-- Empty state -->
        <controls:EmptyStateView Grid.Row="2"
                                 Icon="mdi-shield-off-outline"
                                 Headline="No suppressions to review"
                                 Description="Accepted risks appear here when they need review — expiring soon, expired, or stale. Suppress a finding from the Findings tab to add one."
                                 IsVisible="{Binding !HasReviewItems}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ReviewQueueItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  FrozenColumnCount="2"
                  IsVisible="{Binding HasReviewItems}"

                  CanUserResizeColumns="True"
                  AutomationProperties.AutomationId="SuppressionsDataGrid"
                  AutomationProperties.Name="Suppressions Review Queue">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Status" Width="120" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusBackground}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding StatusLabel}"
                                           Foreground="{Binding StatusForeground}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeXs}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Keep row actions beside Status and frozen. The review grid
                     is wider than its default viewport; when Actions was last,
                     Remove was clipped until a horizontal scroll. -->
                <DataGridTemplateColumn Header="Actions" Width="300" MinWidth="260" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Renew"
                                        AutomationProperties.Name="Renew suppression"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.RenewSuppressionCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding CanRenew}"/>
                                <Button Content="Convert"
                                        AutomationProperties.Name="Convert suppression duration"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.ConvertDurationCommand}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Edit"
                                        AutomationProperties.Name="Edit suppression reason"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.EditReasonCommand}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Remove"
                                        AutomationProperties.Name="Remove suppression"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.RemoveSuppressionCommand}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Rule" Binding="{Binding Entry.RuleId}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Target" Binding="{Binding Entry.Target}" Width="150" MinWidth="130" />
                <DataGridTextColumn Header="Reason" Binding="{Binding Entry.Reason}" Width="*" MinWidth="180" />
                <DataGridTextColumn Header="Created" Binding="{Binding Entry.CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Expires" Binding="{Binding Entry.ExpiresAt, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Review" Binding="{Binding Entry.ReviewDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
