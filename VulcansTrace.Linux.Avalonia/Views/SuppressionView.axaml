<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             x:Class="VulcansTrace.Linux.Avalonia.Views.SuppressionView"
             x:DataType="vm:SuppressionViewModel">

    <Design.DataContext>
        <vm:SuppressionViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <ComboBox ItemsSource="{Binding ReviewFilters}"
                      SelectedItem="{Binding SelectedReviewFilter}"
                      Width="180"
                      VerticalAlignment="Center"
                      Theme="{StaticResource VtComboBox}"
                      AutomationProperties.AutomationId="SuppressionsFilterComboBox">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ReviewFilterLabelConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding ReviewQueueCount, StringFormat='{}Items: {0}'}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="{StaticResource VtTextMutedBrush}"/>
        </StackPanel>

        <!-- Empty state -->
        <controls:EmptyStateView Grid.Row="1"
                                 Icon="mdi-shield-off-outline"
                                 Headline="No suppressions to review"
                                 Description="Accepted risks appear here when they need review — expiring soon, expired, or stale. Suppress a finding from the Findings tab to add one."
                                 IsVisible="{Binding !HasReviewItems}"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ReviewQueueItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  IsVisible="{Binding HasReviewItems}"

                  CanUserResizeColumns="True"
                  AutomationProperties.AutomationId="SuppressionsDataGrid"
                  AutomationProperties.Name="Suppressions Review Queue">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Status" Width="120" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusBackground}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding StatusLabel}"
                                           Foreground="{Binding StatusForeground}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeXs}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Rule" Binding="{Binding Entry.RuleId}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Target" Binding="{Binding Entry.Target}" Width="150" MinWidth="130" />
                <DataGridTextColumn Header="Reason" Binding="{Binding Entry.Reason}" Width="*" MinWidth="180" />
                <DataGridTextColumn Header="Created" Binding="{Binding Entry.CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Expires" Binding="{Binding Entry.ExpiresAt, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Review" Binding="{Binding Entry.ReviewDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120" MinWidth="110" />
                <DataGridTemplateColumn Header="Actions" Width="300" MinWidth="260" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Renew"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.RenewSuppressionCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding CanRenew}"/>
                                <Button Content="Convert"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.ConvertDurationCommand}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Edit"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.EditReasonCommand}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Remove"
                                        FontSize="{StaticResource VtFontSizeXs}"
                                        Padding="4,2"
                                        Theme="{StaticResource VtGhostButton}"
                                        Command="{Binding $parent[DataGrid].DataContext.RemoveSuppressionCommand}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
