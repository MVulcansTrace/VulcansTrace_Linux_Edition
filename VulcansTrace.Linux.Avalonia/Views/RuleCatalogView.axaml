<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             x:Class="VulcansTrace.Linux.Avalonia.Views.RuleCatalogView"
             x:DataType="vm:RuleCatalogViewModel">

    <Design.DataContext>
        <vm:RuleCatalogViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource VtTextSecondaryBrush}"/>
            <TextBox Text="{Binding SearchText}"
                     Width="320"
                     VerticalAlignment="Center"
                     Theme="{StaticResource VtInput}"
                     AutomationProperties.AutomationId="RulesSearchTextBox"
                     AutomationProperties.Name="Search rules"/>
            <TextBlock Text="Total rules: " VerticalAlignment="Center" Margin="12,0,4,0" Foreground="{StaticResource VtTextMutedBrush}"/>
            <TextBlock Text="{Binding TotalRules}" VerticalAlignment="Center" Foreground="{StaticResource VtTextPrimaryBrush}" FontWeight="Bold"/>
            <Button Content="Edit Policy"
                    Command="{Binding EditPolicyCommand}"
                    VerticalAlignment="Center"
                    Margin="16,0,0,0"
                    MinWidth="100"
                    Theme="{StaticResource VtPrimaryButton}"
                    AutomationProperties.AutomationId="EditRulePolicyButton"/>
            <TextBlock Text="{Binding PolicyStatusMessage}"
                       IsVisible="{Binding HasPolicyStatusMessage}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       MaxWidth="460"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource VtTextSecondaryBrush}"
                       FontSize="{StaticResource VtFontSizeSm}"
                       AutomationProperties.AutomationId="RulePolicyStatusMessage"
                       AutomationProperties.Name="Rule policy status"/>
        </WrapPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding FilteredItems}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  IsVisible="{Binding HasData}"
                  CanUserResizeColumns="True"
                  AutomationProperties.AutomationId="RulesDataGrid"
                  AutomationProperties.Name="Rules Catalog Table">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Severity" Width="130" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="2">
                                <TextBlock Text="{Binding Severity}"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityToForegroundBrushConverter}}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource VtFontSizeSm}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="120" MinWidth="110" />
                <DataGridTextColumn Header="Policy" Binding="{Binding PolicyOverrideDisplay}" Width="120" MinWidth="100" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category, Converter={StaticResource CategoryLabelConverter}}" Width="140" MinWidth="130" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" MinWidth="180" />
                <DataGridTextColumn Header="What It Checks" Binding="{Binding WhatItChecks}" Width="2*" MinWidth="180" />
                <DataGridTextColumn Header="MITRE" Binding="{Binding MitreTechniquesDisplay}" Width="Auto" MinWidth="110" />
                <DataGridTextColumn Header="Sources" Binding="{Binding DataSources}" Width="*" MinWidth="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Filter excluded everything: show a targeted hint instead of the never-loaded empty state. -->
        <controls:FilterEmptyStateView Grid.Row="1"
                                       IsVisible="{Binding HasNoFilterMatches}"
                                       Icon="mdi-filter-remove-outline"
                                       Headline="No rules match your search"
                                       Description="Adjust the search box above to widen the results."/>

        <!-- No catalog loaded. The catalog is built into VulcansTrace and loads at startup, so this
             state only appears if startup failed or the catalog file is missing. -->
        <controls:EmptyStateView Grid.Row="1"
                                 AutomationProperties.AutomationId="RulesEmptyState"
                                 AutomationProperties.Name="Rule catalog empty state"
                                 Icon="mdi-book-open-variant"
                                 Headline="No rules loaded"
                                 Description="The rule catalog is built into VulcansTrace and loads at startup, with severity, what each one checks, and the data sources it needs. If this view is empty, the catalog failed to load — restart the app and check the logs."
                                 IsVisible="{Binding !HasItems}"/>
    </Grid>
</UserControl>
