<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        x:Class="VulcansTrace.Linux.Avalonia.Views.ScheduleEditWindow"
        x:DataType="vm:ScheduleEditViewModel"
        Title="Edit Schedule"
        Width="420"
        Height="640"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:ScheduleEditViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Schedule Name:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" Text="{Binding Name}" PlaceholderText="e.g. Daily Full Audit" Theme="{StaticResource VtInput}" Margin="0,0,0,12" AutomationProperties.AutomationId="ScheduleNameInput" AutomationProperties.Name="Schedule name"/>

        <TextBlock Grid.Row="2" Text="Intent:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="3" ItemsSource="{Binding AvailableIntents}" SelectedItem="{Binding Intent}" Theme="{StaticResource VtComboBox}" Margin="0,0,0,12" AutomationProperties.AutomationId="ScheduleIntentComboBox" AutomationProperties.Name="Schedule intent"/>

        <TextBlock Grid.Row="4" Text="Cron Expression:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="5" Text="{Binding CronExpression}" PlaceholderText="e.g. 0 6 * * *" Theme="{StaticResource VtInput}" Margin="0,0,0,12" AutomationProperties.AutomationId="ScheduleCronExpressionInput" AutomationProperties.Name="Schedule cron expression"/>

        <TextBlock Grid.Row="6" Text="Machine Role:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="7" ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding MachineRole}" Theme="{StaticResource VtComboBox}" Margin="0,0,0,12" AutomationProperties.AutomationId="ScheduleMachineRoleComboBox" AutomationProperties.Name="Schedule machine role"/>

        <StackPanel Grid.Row="8" Orientation="Vertical" Spacing="8">
            <TextBlock Text="Output Directory (optional):" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
            <TextBox Text="{Binding OutputDirectory}" PlaceholderText="/var/log/vulcanstrace" Theme="{StaticResource VtInput}" AutomationProperties.AutomationId="ScheduleOutputDirectoryInput" AutomationProperties.Name="Schedule output directory"/>

            <TextBlock Text="Notification Channel:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableChannels}" SelectedItem="{Binding NotificationChannel}" Theme="{StaticResource VtComboBox}" AutomationProperties.AutomationId="ScheduleNotificationChannelComboBox" AutomationProperties.Name="Schedule notification channel"/>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox Content="Notify on critical findings" IsChecked="{Binding NotifyOnCritical}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <CheckBox Content="Enabled" IsChecked="{Binding Enabled}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox Content="Autonomous drift response" IsChecked="{Binding AutonomousDriftResponse}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding AutonomousDriftResponse}">
                    <TextBlock Text="Threshold:" VerticalAlignment="Center" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    <ComboBox ItemsSource="{Binding AvailableSeverities}" SelectedItem="{Binding AutonomousDriftSeverityThreshold}" Theme="{StaticResource VtComboBox}" AutomationProperties.AutomationId="ScheduleDriftSeverityComboBox" AutomationProperties.Name="Autonomous drift severity threshold"/>
                </StackPanel>
            </StackPanel>

            <CheckBox Content="Require signed alerts (skip unsigned drift alerts when no signing key is set)" IsChecked="{Binding RequireSignedAlerts}" IsVisible="{Binding AutonomousDriftResponse}" Foreground="{StaticResource VtTextPrimaryBrush}"/>

            <StackPanel Orientation="Vertical" Spacing="4">
                <CheckBox Content="Allow human-approved remediation" IsChecked="{Binding AllowAutoRemediate}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <StackPanel Orientation="Vertical" Spacing="4" IsVisible="{Binding AllowAutoRemediate}" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Permit service restarts" IsChecked="{Binding AllowRemediationRestart}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                        <CheckBox Content="Permit package install/remove" IsChecked="{Binding AllowRemediationPackages}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Limit to rule prefixes (comma-separated, optional):" Foreground="{StaticResource VtTextSecondaryBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                    <TextBox Text="{Binding RemediationPrefixes}" PlaceholderText="e.g. FW, KERN, PKG" Theme="{StaticResource VtInput}" AutomationProperties.AutomationId="ScheduleRemediationPrefixesInput" AutomationProperties.Name="Schedule remediation rule prefixes"/>
                    <TextBlock Text="Available prefixes: FW, KERN, PKG, SSH, USER, FILE, LOG, CRON, CONTAINER, K8S, PROCESS" Foreground="{StaticResource VtTextMutedBrush}" FontSize="{StaticResource VtFontSizeSm}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="ValidationError" Text="" Foreground="{StaticResource VtDangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                <Button x:Name="OkButton" Content="Save" MinWidth="80" Theme="{StaticResource VtPrimaryButton}" Click="OkButton_Click" AutomationProperties.AutomationId="ScheduleSaveButton" AutomationProperties.Name="Save schedule"/>
                <Button x:Name="CancelButton" Content="Cancel" MinWidth="80" Theme="{StaticResource VtSecondaryButton}" Click="CancelButton_Click" AutomationProperties.AutomationId="ScheduleCancelButton" AutomationProperties.Name="Cancel schedule editing"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
