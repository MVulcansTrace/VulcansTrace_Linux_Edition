<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:notifications="using:VulcansTrace.Linux.Agent.Notifications"
             x:Class="VulcansTrace.Linux.Avalonia.Views.NotificationSettingsView"
             x:DataType="vm:NotificationSettingsViewModel">

    <Design.DataContext>
        <vm:NotificationSettingsViewModel/>
    </Design.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Notification Channel Settings"
                       FontSize="{StaticResource VtFontSizeXl}"
                       FontWeight="Bold"
                       Foreground="{StaticResource VtTextPrimaryBrush}"/>

            <CheckBox Content="Enable notifications"
                      IsChecked="{Binding Enabled}"
                      Foreground="{StaticResource VtTextPrimaryBrush}"
                      AutomationProperties.AutomationId="NotificationEnabledCheckBox"/>

            <TextBlock Text="Channel:"
                       FontWeight="Bold"
                       Foreground="{StaticResource VtTextPrimaryBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableChannels}"
                      SelectedItem="{Binding SelectedChannel}"
                      Width="280"
                      HorizontalAlignment="Left"
                      AutomationProperties.AutomationId="NotificationChannelComboBox"
                      AutomationProperties.Name="Channel">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="notifications:NotificationChannel">
                        <TextBlock Text="{Binding ., Converter={StaticResource NotificationChannelLabelConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Desktop section -->
            <Border IsVisible="{Binding IsDesktopSelected}"
                       Background="{StaticResource VtBackground800Brush}"
                       Padding="12"
                       CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Desktop notifications use notify-send. No additional configuration is required."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource VtTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Email section -->
            <Border IsVisible="{Binding IsEmailSelected}"
                       Background="{StaticResource VtBackground800Brush}"
                       Padding="12"
                       CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="SMTP Settings"
                               FontWeight="Bold"
                               Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    
                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <Grid.Styles>
                            <Style Selector="TextBox, CheckBox">
                                <Setter Property="Margin" Value="0,4"/>
                            </Style>
                        </Grid.Styles>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EmailSmtpHost}" PlaceholderText="smtp.example.com" AutomationProperties.AutomationId="NotificationEmailHostTextBox" AutomationProperties.Name="SMTP host"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EmailSmtpPort}" AutomationProperties.AutomationId="NotificationEmailPortTextBox" AutomationProperties.Name="SMTP port"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="From:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EmailFrom}" PlaceholderText="vulcanstrace@example.com" AutomationProperties.AutomationId="NotificationEmailFromTextBox" AutomationProperties.Name="Notification email sender"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="To:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EmailTo}" PlaceholderText="admin@example.com" AutomationProperties.AutomationId="NotificationEmailToTextBox" AutomationProperties.Name="Notification email recipient"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EmailUsername}" AutomationProperties.AutomationId="NotificationEmailUsernameTextBox" AutomationProperties.Name="SMTP username"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EmailPassword}" PasswordChar="*" AutomationProperties.AutomationId="NotificationEmailPasswordTextBox" AutomationProperties.Name="SMTP password"/>
                    </Grid>

                    <CheckBox Content="Enable SSL/TLS"
                              IsChecked="{Binding EmailEnableSsl}"
                              Foreground="{StaticResource VtTextPrimaryBrush}"
                              AutomationProperties.AutomationId="NotificationEmailSslCheckBox"/>
                </StackPanel>
            </Border>

            <!-- Webhook section -->
            <Border IsVisible="{Binding IsWebhookSelected}"
                       Background="{StaticResource VtBackground800Brush}"
                       Padding="12"
                       CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Webhook URL"
                               FontWeight="Bold"
                               Foreground="{StaticResource VtTextPrimaryBrush}"/>
                    
                    <TextBox Text="{Binding WebhookUrl}"
                             PlaceholderText="https://hooks.example.com/vulcanstrace"
                             AutomationProperties.AutomationId="NotificationWebhookUrlTextBox"
                             AutomationProperties.Name="Notification webhook URL"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource VtTextMutedBrush}"
                       FontSize="{StaticResource VtFontSizeSm}"
                       TextWrapping="Wrap"
                       AutomationProperties.AutomationId="NotificationSettingsStatusTextBlock"
                       AutomationProperties.Name="Notification settings status"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Theme="{StaticResource VtPrimaryButton}"
                        MinWidth="80"
                        AutomationProperties.AutomationId="NotificationSettingsSaveButton"/>
                
                <Button Content="Test"
                        Command="{Binding TestCommand}"
                        Theme="{StaticResource VtSecondaryButton}"
                        MinWidth="80"
                        AutomationProperties.AutomationId="NotificationSettingsTestButton"/>
                
                <Button Content="Reset"
                        Command="{Binding ResetCommand}"
                        Theme="{StaticResource VtSecondaryButton}"
                        MinWidth="80"
                        AutomationProperties.AutomationId="NotificationSettingsResetButton"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
