<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        x:Class="VulcansTrace.Linux.Avalonia.Views.RulePolicyEditWindow"
        x:DataType="vm:RulePolicyEditViewModel"
        Title="Edit Rule Policy"
        Width="460"
        Height="520"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:RulePolicyEditViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Rule:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="{Binding RuleId}" FontWeight="SemiBold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="2" Text="{Binding RuleDescription}" TextWrapping="Wrap" Foreground="{StaticResource VtTextSecondaryBrush}" FontSize="{StaticResource VtFontSizeSm}" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="Machine Role:" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="4"
                  x:Name="RoleComboBox"
                  ItemsSource="{Binding AvailableRoles}"
                  SelectedItem="{Binding SelectedRole, Mode=OneWay}"
                  SelectionChanged="RoleComboBox_SelectionChanged"
                  Theme="{StaticResource VtComboBox}"
                  Margin="0,0,0,12"/>

        <StackPanel Grid.Row="5" Orientation="Vertical" Spacing="8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <CheckBox Content="Override Enabled" IsChecked="{Binding HasEnabled}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <CheckBox Content="Enabled" IsChecked="{Binding Enabled}" IsEnabled="{Binding HasEnabled}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <CheckBox Content="Override Severity" IsChecked="{Binding HasSeverityOverride}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding AvailableSeverities}" SelectedItem="{Binding SeverityOverride}" IsEnabled="{Binding HasSeverityOverride}" Theme="{StaticResource VtComboBox}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <CheckBox Content="Override Auto-Pass" IsChecked="{Binding HasAutoPass}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                <CheckBox Content="Auto-Pass" IsChecked="{Binding AutoPass}" IsEnabled="{Binding HasAutoPass}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="Parameters (one key=value per line, # comments allowed):" FontWeight="Bold" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBox Grid.Row="7" Text="{Binding ParametersText}" AcceptsReturn="True" TextWrapping="Wrap" PlaceholderText="treatDefaultAs=Fail&#x0a;expectedPublicPorts=22,80,443" Theme="{StaticResource VtInput}" Height="120" Margin="0,0,0,12"/>

        <TextBlock x:Name="ValidationError" Grid.Row="8" Text="{Binding ValidationMessage}" Foreground="{StaticResource VtDangerBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Save" MinWidth="80" Theme="{StaticResource VtPrimaryButton}" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="80" Theme="{StaticResource VtSecondaryButton}" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
