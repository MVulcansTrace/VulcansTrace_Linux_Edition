<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
        x:Class="VulcansTrace.Linux.Avalonia.Views.AuditDiffWindow"
        x:DataType="vm:AuditDiffViewModel"
        Title="Audit Diff"
        Width="700"
        Height="520"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter">

    <Window.Resources>
        <conv:IntToBoolConverter x:Key="IntToBoolConverter" />
    </Window.Resources>


    <Design.DataContext>
        <vm:AuditDiffViewModel/>
    </Design.DataContext>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*">
        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Audit Comparison"
                   FontSize="{StaticResource VtFontSize2xl}"
                   FontWeight="Bold"
                   Foreground="{StaticResource VtTextPrimaryBrush}"
                   Margin="0,0,0,8"/>

        <!-- Narrative -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Narrative}"
                   FontSize="{StaticResource VtFontSizeMd}"
                   Foreground="{StaticResource VtTextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Summary badges -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="New: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding NewCount}" FontWeight="Bold" Foreground="{StaticResource VtSuccessBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Resolved: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding ResolvedCount}" FontWeight="Bold" Foreground="{StaticResource VtTextMutedBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Worsened: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding WorsenedCount}" FontWeight="Bold" Foreground="{StaticResource VtDangerBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Improved: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding ImprovedCount}" FontWeight="Bold" Foreground="{StaticResource VtPrimaryBrush}"/>
                </TextBlock>
            </Border>
            <Border Background="{StaticResource VtBackground800Brush}" Padding="8,4" CornerRadius="{StaticResource VtRadiusLg}" BorderBrush="{StaticResource VtBorderDefaultBrush}" BorderThickness="1">
                <TextBlock>
                    <Run Text="Confidence: " Foreground="{StaticResource VtTextSecondaryBrush}"/><Run Text="{Binding ConfidenceChangedCount}" FontWeight="Bold" Foreground="{StaticResource VtInfoBrush}"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- Diff sections -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- New findings -->
                <Border Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtSuccessBrush}" BorderThickness="1" CornerRadius="{StaticResource VtRadiusLg}" Padding="10"
                        IsVisible="{Binding NewCount, Converter={StaticResource IntToBoolConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="New Findings" FontWeight="Bold" Foreground="{StaticResource VtSuccessBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                        <ItemsControl ItemsSource="{Binding NewFindings}" AutomationProperties.AutomationId="AuditDiffNewFindingsList" AutomationProperties.Name="New audit findings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,2">
                                        <Run Text="+" Foreground="{StaticResource VtSuccessBrush}" FontWeight="Bold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RuleId}" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Confidence}" Foreground="{StaticResource VtInfoBrush}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding ShortDescription}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Resolved findings -->
                <Border Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtTextMutedBrush}" BorderThickness="1" CornerRadius="{StaticResource VtRadiusLg}" Padding="10"
                        IsVisible="{Binding ResolvedCount, Converter={StaticResource IntToBoolConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Resolved Findings" FontWeight="Bold" Foreground="{StaticResource VtTextSecondaryBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                        <ItemsControl ItemsSource="{Binding ResolvedFindings}" AutomationProperties.AutomationId="AuditDiffResolvedFindingsList" AutomationProperties.Name="Resolved audit findings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,2">
                                        <Run Text="✓" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RuleId}" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Confidence}" Foreground="{StaticResource VtInfoBrush}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding ShortDescription}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Worsened findings -->
                <Border Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtDangerHoverBrush}" BorderThickness="1" CornerRadius="{StaticResource VtRadiusLg}" Padding="10"
                        IsVisible="{Binding WorsenedCount, Converter={StaticResource IntToBoolConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Worsened Severity" FontWeight="Bold" Foreground="{StaticResource VtDangerBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                        <ItemsControl ItemsSource="{Binding WorsenedFindings}" AutomationProperties.AutomationId="AuditDiffWorsenedFindingsList" AutomationProperties.Name="Worsened audit findings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,2">
                                        <Run Text="↑" Foreground="{StaticResource VtDangerBrush}" FontWeight="Bold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RuleId}" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding OldSeverity}" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                        <Run Text=" → "/>
                                        <Run Text="{Binding NewSeverity}" Foreground="{StaticResource VtDangerBrush}" FontWeight="Bold"/>
                                        <Run Text=" confidence "/>
                                        <Run Text="{Binding NewConfidence}" Foreground="{StaticResource VtInfoBrush}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding ShortDescription}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Improved findings -->
                <Border Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtPrimaryGlowBrush}" BorderThickness="1" CornerRadius="{StaticResource VtRadiusLg}" Padding="10"
                        IsVisible="{Binding ImprovedCount, Converter={StaticResource IntToBoolConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Improved Severity" FontWeight="Bold" Foreground="{StaticResource VtPrimaryBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                        <ItemsControl ItemsSource="{Binding ImprovedFindings}" AutomationProperties.AutomationId="AuditDiffImprovedFindingsList" AutomationProperties.Name="Improved audit findings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,2">
                                        <Run Text="↓" Foreground="{StaticResource VtPrimaryBrush}" FontWeight="Bold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RuleId}" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding OldSeverity}" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                        <Run Text=" → "/>
                                        <Run Text="{Binding NewSeverity}" Foreground="{StaticResource VtPrimaryBrush}" FontWeight="Bold"/>
                                        <Run Text=" confidence "/>
                                        <Run Text="{Binding NewConfidence}" Foreground="{StaticResource VtInfoBrush}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding ShortDescription}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Confidence changes -->
                <Border Background="{StaticResource VtBackground900Brush}" BorderBrush="{StaticResource VtPrimaryHoverBrush}" BorderThickness="1" CornerRadius="{StaticResource VtRadiusLg}" Padding="10"
                        IsVisible="{Binding ConfidenceChangedCount, Converter={StaticResource IntToBoolConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Changed Confidence" FontWeight="Bold" Foreground="{StaticResource VtInfoBrush}" FontSize="{StaticResource VtFontSizeMd}"/>
                        <ItemsControl ItemsSource="{Binding ConfidenceChangedFindings}" AutomationProperties.AutomationId="AuditDiffConfidenceChangesList" AutomationProperties.Name="Audit finding confidence changes">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="{StaticResource VtFontSizeSm}" Foreground="{StaticResource VtTextPrimaryBrush}" Margin="0,2">
                                        <Run Text="~" Foreground="{StaticResource VtInfoBrush}" FontWeight="Bold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding RuleId}" FontWeight="SemiBold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding OldConfidence}" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                        <Run Text=" → "/>
                                        <Run Text="{Binding NewConfidence}" Foreground="{StaticResource VtInfoBrush}" FontWeight="Bold"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding ShortDescription}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
