<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.IncidentStoryView"
             x:DataType="vm:IncidentStoryViewModel">

    <Design.DataContext>
        <vm:IncidentStoryViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Empty state -->
        <Border Grid.Row="0"
                Background="#1e293b"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,8"
                IsVisible="{Binding !HasStory}">
            <TextBlock Text="Run an analysis or agent audit to generate an incident story."
                       Foreground="#94a3b8"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Story content -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding HasStory}">
            <StackPanel Spacing="12" Margin="0,0,8,0">
                <!-- Toolbar -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Incident Story"
                               Foreground="#e2e8f0"
                               FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Copy Markdown"
                                Padding="8,4"
                                FontSize="12"
                                Command="{Binding CopyMarkdownCommand}"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding CopyStatus}"
                           Foreground="#4ade80"
                           FontSize="11"
                           IsVisible="{Binding CopyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Critical chain badge -->
                <Border Background="#3f1515"
                        BorderBrush="#991b1b"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        IsVisible="{Binding HasCriticalChain}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Critical attack chain detected"
                                   Foreground="#fecaca"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Timeline beats -->
                <Border Background="#1e293b"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Timeline"
                                   Foreground="#e2e8f0"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Beats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="•"
                                                   Foreground="#60a5fa"
                                                   FontSize="12"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="[" Foreground="#94a3b8"/>
                                            <Run Text="{Binding TimestampLabel}" Foreground="#94a3b8" FontFamily="Consolas,Monospace"/>
                                            <Run Text="]" Foreground="#94a3b8"/>
                                            <Run Text=" " Foreground="#e2e8f0"/>
                                            <Run Text="{Binding Narrative}" Foreground="#e2e8f0"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Likely chain -->
                <Border Background="#1e293b"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Likely Chain"
                                   Foreground="#e2e8f0"
                                   FontWeight="Bold"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding LikelyChain}"
                                   Foreground="#cbd5e1"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Recommendations -->
                <Border Background="#1e293b"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recommended Response"
                                   Foreground="#e2e8f0"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="→"
                                                   Foreground="#4ade80"
                                                   FontSize="12"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#cbd5e1"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
