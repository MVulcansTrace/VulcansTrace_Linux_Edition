<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             x:Class="VulcansTrace.Linux.Avalonia.Views.IncidentStoryView"
             x:DataType="vm:IncidentStoryViewModel">

    <Design.DataContext>
        <vm:IncidentStoryViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Empty state -->
        <Border Grid.Row="0"
                Theme="{StaticResource VtCard}"
                Margin="0,0,0,8"
                IsVisible="{Binding !HasStory}">
            <TextBlock Text="Run an analysis or agent audit to generate an incident story."
                       Foreground="{StaticResource VtTextMutedBrush}"
                       FontSize="{StaticResource VtFontSizeMd}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Story content -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding HasStory}">
            <StackPanel Spacing="12" Margin="0,0,8,0">
                <!-- Toolbar -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Incident Story"
                               Foreground="{StaticResource VtTextPrimaryBrush}"
                               FontWeight="Bold"
                               FontSize="{StaticResource VtFontSizeXl}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Copy Markdown"
                                Padding="8,4"
                                FontSize="{StaticResource VtFontSizeSm}"
                                Theme="{StaticResource VtSecondaryButton}"
                                Command="{Binding CopyMarkdownCommand}"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding CopyStatus}"
                           Foreground="{StaticResource VtSuccessBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           IsVisible="{Binding CopyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Critical chain badge -->
                <Border Background="{StaticResource VtDangerMutedBrush}"
                        BorderBrush="{StaticResource VtDangerHoverBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VtRadiusLg}"
                        Padding="10,6"
                        IsVisible="{Binding HasCriticalChain}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⚠️" FontSize="{StaticResource VtFontSizeXl}" VerticalAlignment="Center" Foreground="{StaticResource VtDangerBrush}"/>
                        <TextBlock Text="Critical attack chain detected"
                                   Foreground="{StaticResource VtDangerBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeMd}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Timeline beats -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Timeline"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Beats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="•"
                                                   Foreground="{StaticResource VtPrimaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeSm}"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="[" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                            <Run Text="{Binding TimestampLabel}" Foreground="{StaticResource VtTextSecondaryBrush}" FontFamily="{StaticResource VtFontFamilyMono}"/>
                                            <Run Text="]" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                            <Run Text=" " Foreground="{StaticResource VtTextPrimaryBrush}"/>
                                            <Run Text="{Binding Narrative}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Likely chain -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Likely Chain"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"/>
                        <TextBlock Text="{Binding LikelyChain}"
                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                   FontSize="{StaticResource VtFontSizeMd}"
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Recommendations -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recommended Response"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="→"
                                                   Foreground="{StaticResource VtSuccessBrush}"
                                                   FontSize="{StaticResource VtFontSizeSm}"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeMd}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
