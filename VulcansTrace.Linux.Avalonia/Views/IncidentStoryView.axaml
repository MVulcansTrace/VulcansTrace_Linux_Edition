<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
             xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
             x:Class="VulcansTrace.Linux.Avalonia.Views.IncidentStoryView"
             x:DataType="vm:IncidentStoryViewModel">

    <Design.DataContext>
        <vm:IncidentStoryViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <!-- Bound to CopyStatusIsError: true (failure) → red, false (success) → green. -->
        <conv:BoolToBrushConverter x:Key="CopyStatusBrushConverter"
                                   TrueBrush="{StaticResource VtDangerBrush}"
                                   FalseBrush="{StaticResource VtSuccessBrush}"/>
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <!-- Empty state -->
        <controls:EmptyStateView Grid.Row="0"
                                 AutomationProperties.AutomationId="IncidentStoryEmptyState"
                                 AutomationProperties.Name="Incident story empty state"
                                 Icon="mdi-book-open-variant"
                                 Headline="{Binding EmptyStateHeadline}"
                                 Description="{Binding EmptyStateDescription}"
                                 ActionText="{Binding EmptyStateActionText}"
                                 ActionCommand="{Binding EmptyStateActionCommand}"
                                 ActionIcon="mdi-rocket-launch-outline"
                                 ActionAutomationId="IncidentStoryEmptyStateAnalyzeButton"
                                 ActionAutomationName="Run audit for incident story"
                                 IsVisible="{Binding !HasStory}"/>

        <!-- Story content -->
        <ScrollViewer Grid.Row="0"
                      IsVisible="{Binding HasStory}">
            <StackPanel Spacing="12" Margin="0,0,8,0">
                <!-- Toolbar -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Incident Story"
                               Foreground="{StaticResource VtTextPrimaryBrush}"
                               FontWeight="Bold"
                               FontSize="{StaticResource VtFontSizeXl}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Copy Markdown"
                                Padding="8,4"
                                FontSize="{StaticResource VtFontSizeSm}"
                                Theme="{StaticResource VtSecondaryButton}"
                                Command="{Binding CopyMarkdownCommand}"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="{Binding CopyStatus}"
                           Foreground="{Binding CopyStatusIsError, Converter={StaticResource CopyStatusBrushConverter}}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           IsVisible="{Binding CopyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Critical chain badge -->
                <Border Background="{StaticResource VtDangerMutedBrush}"
                        BorderBrush="{StaticResource VtDangerHoverBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource VtRadiusLg}"
                        Padding="10,6"
                        IsVisible="{Binding HasCriticalChain}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⚠️" FontSize="{StaticResource VtFontSizeXl}" VerticalAlignment="Center" Foreground="{StaticResource VtDangerBrush}"/>
                        <TextBlock Text="Critical attack chain detected"
                                   Foreground="{StaticResource VtDangerBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeMd}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Likely chain -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Likely Chain"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"/>
                        <TextBlock Text="{Binding LikelyChain}"
                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                   FontSize="{StaticResource VtFontSizeMd}"
                                   TextWrapping="Wrap"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Recommendations -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recommended Response"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}" AutomationProperties.AutomationId="IncidentRecommendationsList" AutomationProperties.Name="Recommended incident response">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="→"
                                                   Foreground="{StaticResource VtSuccessBrush}"
                                                   FontSize="{StaticResource VtFontSizeSm}"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeMd}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- System posture (configuration snapshot findings) -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12"
                        IsVisible="{Binding HasPostureFindings}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="System Posture"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Configuration findings from the latest audit (point-in-time, not events)."
                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2"/>
                        <ItemsControl ItemsSource="{Binding PostureBeats}" AutomationProperties.AutomationId="IncidentPostureFindingsList" AutomationProperties.Name="Incident posture findings">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="•"
                                                   Foreground="{StaticResource VtPrimaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeSm}"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding Narrative}"
                                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeMd}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Timeline beats (log events) -->
                <Border Theme="{StaticResource VtCard}"
                        Padding="12"
                        IsVisible="{Binding HasTimelineFindings}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Timeline"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{StaticResource VtFontSizeXl}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding TimelineBeats}" AutomationProperties.AutomationId="IncidentTimelineList" AutomationProperties.Name="Incident timeline">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="•"
                                                   Foreground="{StaticResource VtPrimaryBrush}"
                                                   FontSize="{StaticResource VtFontSizeSm}"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="[" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                            <Run Text="{Binding TimestampLabel}" Foreground="{StaticResource VtTextSecondaryBrush}" FontFamily="{StaticResource VtFontFamilyMono}"/>
                                            <Run Text="]" Foreground="{StaticResource VtTextSecondaryBrush}"/>
                                            <Run Text=" " Foreground="{StaticResource VtTextPrimaryBrush}"/>
                                            <Run Text="{Binding Narrative}" Foreground="{StaticResource VtTextPrimaryBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
