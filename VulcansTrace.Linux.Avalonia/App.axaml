<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:VulcansTrace.Linux.Avalonia"
             xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
             x:Class="VulcansTrace.Linux.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <local:ViewLocator x:Key="ViewLocator" />
            <conv:SeverityToBrushConverter x:Key="SeverityToBrushConverter" />
            <conv:SeverityToForegroundBrushConverter x:Key="SeverityToForegroundBrushConverter" />
            <conv:ReviewFilterLabelConverter x:Key="ReviewFilterLabelConverter" />
            <conv:NotificationChannelLabelConverter x:Key="NotificationChannelLabelConverter" />
            <conv:CategoryLabelConverter x:Key="CategoryLabelConverter" />
            <conv:GroupModeToBoolConverter x:Key="GroupModeToBoolConverter" />
            <conv:IntToBoolConverter x:Key="IntToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://VulcansTrace.Linux.Avalonia/Themes/VtDesignTokens.axaml" />
    </Application.Styles>
</Application>
