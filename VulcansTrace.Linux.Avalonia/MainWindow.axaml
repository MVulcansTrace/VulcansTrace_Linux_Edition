<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
        xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
        xmlns:local="using:VulcansTrace.Linux.Avalonia"
        xmlns:views="using:VulcansTrace.Linux.Avalonia.Views"
        xmlns:controls="using:VulcansTrace.Linux.Avalonia.Controls"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="VulcansTrace.Linux.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/VulcansTraceAvatar.png"
        Title="VulcansTrace"
        MinWidth="1280"
        MinHeight="800"
        Width="1800"
        Height="1100"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="avares://Avalonia.Fonts.Inter/Assets#Inter"
        FontSize="{StaticResource VtFontSizeMd}">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>


    <Grid Margin="16" Background="{StaticResource VtBackground900Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="56"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- Telemetry strip (compact pills replacing KPI cards) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12"
              IsVisible="{Binding ShowKpiStrip, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <controls:TelemetryPill Icon="mdi-chart-box" Label="Findings"
                    Value="{Binding Findings.FindingsCount, Mode=OneWay}"
                    AccentBrush="{StaticResource VtKpiFindingsBrush}"
                    Command="{Binding KpiNavigateCommand}" CommandParameter="findings"
                    PillAutomationId="KpiFindingsButton"/>
                <controls:TelemetryPill Icon="mdi-alert-octagon" Label="High / Critical"
                    Value="{Binding Findings.HighCriticalCount, Mode=OneWay}"
                    AccentBrush="{StaticResource VtSeverityCriticalBrush}"
                    Command="{Binding KpiNavigateCommand}" CommandParameter="high-critical"
                    PillAutomationId="KpiHighCriticalButton"/>
                <controls:TelemetryPill Icon="mdi-alert" Label="Warnings"
                    Value="{Binding Findings.WarningCount, Mode=OneWay}"
                    AccentBrush="{StaticResource VtSeverityMediumBrush}"
                    Command="{Binding KpiNavigateCommand}" CommandParameter="warnings"
                    PillAutomationId="KpiWarningsButton"/>
                <controls:TelemetryPill Icon="mdi-file-document-alert-outline" Label="Parse Errors"
                    Value="{Binding Findings.ParseErrorCount, Mode=OneWay}"
                    AccentBrush="{StaticResource VtSeverityHighBrush}"
                    Command="{Binding KpiNavigateCommand}" CommandParameter="parse-errors"
                    PillAutomationId="KpiParseErrorsButton"/>
                <controls:TelemetryPill Icon="mdi-skip-next-outline" Label="Skipped"
                    Value="{Binding Findings.SkippedLineCount, Mode=OneWay}"
                    AccentBrush="{StaticResource VtKpiSkippedBrush}"
                    Command="{Binding KpiNavigateCommand}" CommandParameter="skipped"
                    PillAutomationId="KpiSkippedButton"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center"
                        IsVisible="{Binding !IsAgentHomeVisible, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Agent.BaselineStatusText, Mode=OneWay}"
                               Foreground="{StaticResource VtTextSecondaryBrush}"
                               FontSize="{StaticResource VtFontSizeSm}"
                               VerticalAlignment="Center"
                               AutomationProperties.AutomationId="BaselineStatusText"/>
                </StackPanel>
                <TextBlock Text="{Binding Agent.AgentStatus, StringFormat='Agent: {0}'}"
                           Foreground="{StaticResource VtTextSecondaryBrush}"
                           FontSize="{StaticResource VtFontSizeSm}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Sidebar navigation -->
        <controls:NavigationSidebar Grid.Row="1" Grid.Column="0" />

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      Background="{StaticResource VtBorderDefaultBrush}"/>

        <!-- Content zone: status bar (non-agent pages), main content -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Remains visible on the Agent page while main analysis/evidence work is running. -->
            <Border Grid.Row="0"
                    Theme="{StaticResource VtCard}"
                    Padding="10,4"
                    Margin="0,0,0,6"
                    IsVisible="{Binding ShowStatusBar, Mode=OneWay}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <i:Icon Value="mdi-shield-check-outline" FontSize="{StaticResource VtIconSizeMd}" Foreground="{StaticResource VtPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Security Agent" FontWeight="SemiBold" Foreground="{StaticResource VtTextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Agent.AgentStatus, Mode=OneWay}"
                                   AutomationProperties.AutomationId="AgentStatusIndicator"
                                   AutomationProperties.Name="Agent status"
                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   VerticalAlignment="Center"/>
                        <!-- Current page title (every page except the Agent home,
                             where the brand + hero already identify the view). -->
                        <Border Width="1" Height="16" Background="{StaticResource VtBorderDefaultBrush}" VerticalAlignment="Center"
                                IsVisible="{Binding !IsAgentHomeVisible, Mode=OneWay}"/>
                        <TextBlock Text="{Binding CurrentPageTitle, Mode=OneWay}"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource VtFontSizeLg}"
                                   Foreground="{StaticResource VtTextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsVisible="{Binding !IsAgentHomeVisible, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0">
                        <ProgressBar Height="6" Width="140" IsIndeterminate="True" VerticalAlignment="Center"
                                     IsVisible="{Binding IsBusy}"
                                     AutomationProperties.AutomationId="AnalysisBusyProgress"
                                     AutomationProperties.Name="Analysis progress"/>
                        <Button Content="Cancel"
                                Theme="{StaticResource VtSecondaryButton}"
                                AutomationProperties.AutomationId="CancelButton"
                                AutomationProperties.Name="Cancel audit"
                                Command="{Binding CancelCommand}"
                                IsVisible="{Binding IsBusy}"
                                Padding="10,2"
                                FontSize="{StaticResource VtFontSizeSm}"
                                VerticalAlignment="Center"/>
                        <Button Content="Cancel"
                                Theme="{StaticResource VtSecondaryButton}"
                                AutomationProperties.AutomationId="CancelAgentQueryButton"
                                AutomationProperties.Name="Cancel agent query"
                                Command="{Binding Agent.CancelQueryCommand}"
                                IsVisible="{Binding Agent.IsBusy}"
                                Padding="10,2"
                                FontSize="{StaticResource VtFontSizeSm}"
                                VerticalAlignment="Center"/>
                        <Button Content="Cancel Export"
                                Theme="{StaticResource VtSecondaryButton}"
                                AutomationProperties.AutomationId="CancelExportButton"
                                Command="{Binding Evidence.CancelExportCommand}"
                                IsVisible="{Binding Evidence.IsBusy}"
                                Padding="10,2"
                                FontSize="{StaticResource VtFontSizeSm}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource VtTextSecondaryBrush}"
                                   FontSize="{StaticResource VtFontSizeSm}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Theme="{StaticResource VtSecondaryButton}"
                            AutomationProperties.AutomationId="SessionToolsMenu"
                            AutomationProperties.Name="Session tools"
                            VerticalAlignment="Center">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <i:Icon Value="mdi-dots-horizontal" FontSize="{StaticResource VtIconSizeMd}" VerticalAlignment="Center"/>
                                <TextBlock Text="Session tools" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Export Evidence"
                                          Command="{Binding Evidence.ExportEvidenceCommand}"
                                          AutomationProperties.AutomationId="ExportEvidenceButton"/>
                                <MenuItem Header="Compare Logs"
                                          Command="{Binding CompareLogsCommand}"
                                          ToolTip.Tip="Compare two log files for differences"
                                          AutomationProperties.AutomationId="CompareLogsButton"/>
                                <MenuItem Header="Copy Signing Key"
                                          Command="{Binding Evidence.CopySigningKeyCommand}"
                                          ToolTip.Tip="Copy the session HMAC key used to sign exported evidence (needed to verify signatures externally)"
                                          AutomationProperties.AutomationId="CopySigningKeyButton"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>

            <!-- Main content area -->
            <Border Grid.Row="1"
                    Theme="{StaticResource VtCard}"
                    Padding="12">
                <ContentControl x:Name="MainContent"
                                Content="{Binding SelectedContent}" />
            </Border>

            <!-- Machine-readable app state for harnesses: the JSON snapshot rides
                 the TextBlock's own text (its automation peer reports Text as the
                 accessible name; AutomationProperties.* does not reach AT-SPI on
                 Avalonia/Linux). Effectively invisible: 1px, transparent text. -->
            <TextBlock Grid.Row="1"
                       AutomationProperties.AutomationId="AppStateNode"
                       Text="{Binding AppStateJson, Mode=OneWay}"
                       Foreground="Transparent"
                       FontSize="1"
                       Height="1"
                       IsHitTestVisible="False"
                       Focusable="False"/>
        </Grid>

    </Grid>
</Window>
