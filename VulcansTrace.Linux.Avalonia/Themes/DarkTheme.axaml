<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

  <!-- ============================================================ -->
  <!--  Color Palette                                               -->
  <!-- ============================================================ -->

  <SolidColorBrush x:Key="BackgroundPrimary"   Color="#0D1117" />
  <SolidColorBrush x:Key="BackgroundSecondary" Color="#161B22" />
  <SolidColorBrush x:Key="BackgroundTertiary"  Color="#21262D" />
  <SolidColorBrush x:Key="BackgroundInput"     Color="#21262D" />
  <SolidColorBrush x:Key="BackgroundHover"     Color="#30363D" />

  <SolidColorBrush x:Key="Border"       Color="#30363D" />
  <SolidColorBrush x:Key="BorderHover"  Color="#8B949E" />
  <SolidColorBrush x:Key="BorderAccent" Color="#58A6FF" />

  <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3" />
  <SolidColorBrush x:Key="TextSecondary" Color="#8B949E" />
  <SolidColorBrush x:Key="TextMuted"     Color="#6E7681" />
  <SolidColorBrush x:Key="TextInverse"   Color="#0D1117" />

  <SolidColorBrush x:Key="Accent"      Color="#58A6FF" />
  <SolidColorBrush x:Key="AccentHover" Color="#79C0FF" />
  <Color x:Key="AccentGlowColor">#58A6FF4D</Color>
  <SolidColorBrush x:Key="AccentGlow" Color="Transparent" />

  <SolidColorBrush x:Key="SeverityCritical" Color="#F85149" />
  <SolidColorBrush x:Key="SeverityHigh"     Color="#F0883E" />
  <SolidColorBrush x:Key="SeverityMedium"   Color="#D29922" />
  <SolidColorBrush x:Key="SeverityLow"      Color="#3FB950" />
  <SolidColorBrush x:Key="SeverityInfo"     Color="#58A6FF" />

  <SolidColorBrush x:Key="SeverityCriticalBg" Color="#F8514926" />
  <SolidColorBrush x:Key="SeverityHighBg"     Color="#F0883E26" />
  <SolidColorBrush x:Key="SeverityMediumBg"   Color="#D2992226" />
  <SolidColorBrush x:Key="SeverityLowBg"      Color="#3FB95026" />
  <SolidColorBrush x:Key="SeverityInfoBg"     Color="#58A6FF26" />

  <SolidColorBrush x:Key="KpiFindings"      Color="#58A6FF" />
  <SolidColorBrush x:Key="KpiHighCritical"  Color="#F85149" />
  <SolidColorBrush x:Key="KpiWarnings"      Color="#D29922" />
  <SolidColorBrush x:Key="KpiParseErrors"   Color="#F0883E" />
  <SolidColorBrush x:Key="KpiSkipped"       Color="#6E7681" />

  <SolidColorBrush x:Key="LiveRunning" Color="#3FB950" />
  <SolidColorBrush x:Key="LiveStopped" Color="#6E7681" />

  <!-- ============================================================ -->
  <!--  Typography                                                   -->
  <!-- ============================================================ -->

  <system:Double x:Key="FontSizeH1">24</system:Double>
  <system:Double x:Key="FontSizeH2">18</system:Double>
  <system:Double x:Key="FontSizeH3">14</system:Double>
  <system:Double x:Key="FontSizeBody">13</system:Double>
  <system:Double x:Key="FontSizeLabel">11</system:Double>
  <system:Double x:Key="FontSizeSmall">10</system:Double>

  <FontWeight x:Key="FontWeightBold">700</FontWeight>
  <FontWeight x:Key="FontWeightSemiBold">600</FontWeight>
  <FontWeight x:Key="FontWeightMedium">500</FontWeight>
  <FontWeight x:Key="FontWeightRegular">400</FontWeight>

  <!-- ============================================================ -->
  <!--  Spacing                                                      -->
  <!-- ============================================================ -->

  <system:Double x:Key="SpacingSmall">4</system:Double>
  <system:Double x:Key="SpacingMedium">8</system:Double>
  <system:Double x:Key="SpacingLarge">16</system:Double>
  <system:Double x:Key="SpacingXl">24</system:Double>

  <!-- ============================================================ -->
  <!--  Shape                                                        -->
  <!-- ============================================================ -->

  <CornerRadius x:Key="CardRadius">8</CornerRadius>
  <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
  <CornerRadius x:Key="InputRadius">6</CornerRadius>
  <CornerRadius x:Key="PillRadius">99</CornerRadius>

  <!-- ============================================================ -->
  <!--  Tip Bubble (Advisor) Style                                   -->
  <!-- ============================================================ -->

  <SolidColorBrush x:Key="TipBubbleBackground" Color="#161B22" />
  <SolidColorBrush x:Key="TipBubbleBorder"     Color="#30363D" />
  <SolidColorBrush x:Key="TipBubbleTipColor"   Color="#60A5FF" />

</ResourceDictionary>
