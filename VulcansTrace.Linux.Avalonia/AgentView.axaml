<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VulcansTrace.Linux.Avalonia.ViewModels"
             xmlns:conv="using:VulcansTrace.Linux.Avalonia.Converters"
             xmlns:explanations="using:VulcansTrace.Linux.Agent.Explanations"
             xmlns:sessions="using:VulcansTrace.Linux.Agent.Sessions"
             x:Class="VulcansTrace.Linux.Avalonia.AgentView"
             x:DataType="vm:AgentViewModel">

    <Design.DataContext>
        <vm:AgentViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <conv:BoolToColumnConverter x:Key="BoolToColumnConverter" />
        <conv:BoolToSpanConverter x:Key="BoolToSpanConverter" />
        <conv:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter" />
        <conv:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter" />
        <conv:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter" />
        <conv:BoolToForegroundConverter x:Key="BoolToForegroundConverter" />
        <conv:IntToBoolConverter x:Key="IntToBoolConverter" />

        <DataTemplate x:Key="CommandRowTemplate" DataType="explanations:CopyableCommand">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Background="#1e293b"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,2"
                        MaxWidth="380">
                    <TextBlock Text="{Binding DisplayText}"
                               FontFamily="Consolas,Monospace"
                               FontSize="11"
                               Foreground="#e2e8f0"
                               TextWrapping="Wrap"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="{Binding Safety, Converter={x:Static conv:CommandSafetyToBrushConverter.Instance}}">
                    <TextBlock Text="{Binding Safety}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{Binding Safety, Converter={x:Static conv:CommandSafetyToForegroundConverter.Instance}}"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="#3f2e14"
                        IsVisible="{Binding Analysis.RequiresSudo}">
                    <TextBlock Text="SUDO"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#fcd34d"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="#2e1065"
                        IsVisible="{Binding Analysis.HasChain}">
                    <TextBlock Text="CHAIN"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#c084fc"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="#1e3a5f"
                        IsVisible="{Binding Analysis.HasPipe}">
                    <TextBlock Text="PIPE"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#60a5fa"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="#3f2e14"
                        IsVisible="{Binding Analysis.HasRedirect}">
                    <TextBlock Text="REDIR"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#fcd34d"/>
                </Border>
                <Border CornerRadius="4"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="#450a0a"
                        IsVisible="{Binding Analysis.DownloadsAndExecutes}">
                    <TextBlock Text="DL-EXEC"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#f87171"/>
                </Border>
                <Button Content="Copy"
                        FontSize="10"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Click="OnCopyCommandClick"
                        Tag="{Binding FullCommand}"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="0">
        <Border Grid.Row="0" Background="#1e293b" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="8,4">
            <TextBlock Text="Security Agent" FontWeight="Bold" Foreground="#e2e8f0" FontSize="12"/>
        </Border>

        <!-- Privilege warning banner -->
        <Border Grid.Row="1"
                Background="#3f2e14"
                BorderBrush="#854d0e"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                IsVisible="{Binding HasPrivilegeWarning}">
            <TextBlock Text="{Binding PrivilegeWarningText}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="#fcd34d"/>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto,Auto,Auto,Auto">
            <!-- Chat filters -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,4,8,0">
                <ComboBox ItemsSource="{Binding ChatSeverityFilters}"
                          SelectedItem="{Binding SelectedChatSeverityFilter}"
                          FontSize="11"
                          Padding="4,2"
                          MaxDropDownHeight="120"/>
                <ComboBox ItemsSource="{Binding ChatCategoryFilters}"
                          SelectedItem="{Binding SelectedChatCategoryFilter}"
                          FontSize="11"
                          Padding="4,2"
                          MaxDropDownHeight="120"
                          PlaceholderText="All categories"/>
                <Button Content="Clear"
                        FontSize="11"
                        Padding="4,2"
                        Command="{Binding ClearChatFiltersCommand}"/>
            </StackPanel>

            <!-- Chat history -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}" Margin="8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AgentMessageViewModel">
                            <Grid ColumnDefinitions="Auto,*"
                                  IsVisible="{Binding IsVisible}">
                                <!-- User messages align right -->
                                <Border Grid.Column="{Binding IsUser, Converter={StaticResource BoolToColumnConverter}}"
                                        Grid.ColumnSpan="{Binding IsUser, Converter={StaticResource BoolToSpanConverter}}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Background="{Binding IsUser, Converter={StaticResource BoolToBackgroundConverter}}"
                                        BorderBrush="{Binding IsUser, Converter={StaticResource BoolToBorderBrushConverter}}"
                                        BorderThickness="1"
                                        MaxWidth="520"
                                        HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignmentConverter}}">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{Binding IsUser, Converter={StaticResource BoolToForegroundConverter}}"/>
                                        <TextBlock Text="{Binding Details}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#94a3b8"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   IsVisible="{Binding Details, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,4,0,0"
                                                    IsVisible="{Binding HasConfidence}">
                                            <TextBlock Text="{Binding Confidence, StringFormat='{}Confidence: {0}'}"
                                                       Foreground="#93c5fd"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding EvidenceSignalsDisplay, StringFormat='{}Signals: {0}'}"
                                                       Foreground="#94a3b8"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding HasEvidenceSignals}"/>
                                        </StackPanel>
                                        <!-- Verification commands with copy buttons and safety badges -->
                                        <StackPanel Orientation="Vertical"
                                                    Margin="0,6,0,0"
                                                    IsVisible="{Binding HasVerificationCommands}"
                                                    Spacing="4">
                                            <TextBlock Text="How to verify:" FontSize="10" Foreground="#64748b" FontWeight="SemiBold"/>
                                            <ItemsControl ItemsSource="{Binding VerificationCommands}"
                                                          ItemTemplate="{StaticResource CommandRowTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="4"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                        <!-- Interactive Remediation -->
                                        <StackPanel Orientation="Vertical"
                                                    Margin="0,8,0,0"
                                                    IsVisible="{Binding HasRemediationSection}"
                                                    Spacing="8">
                                            <!-- Preconditions -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasPreconditions}"
                                                        Spacing="3">
                                                <TextBlock Text="Preconditions:" FontSize="10" Foreground="#64748b" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding RemediationPreconditions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="☐" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#e2e8f0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Backup Commands -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasBackupCommands}"
                                                        Spacing="4">
                                                <TextBlock Text="Backup commands — run these first to preserve state:" FontSize="10" Foreground="#fcd34d" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding RemediationBackupCommands}"
                                                              ItemTemplate="{StaticResource CommandRowTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Impact Preview -->
                                            <Border Background="#0f172a"
                                                    BorderBrush="#334155"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8,6"
                                                    IsVisible="{Binding HasImpactPreview}">
                                                <StackPanel Orientation="Vertical" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="ℹ️" FontSize="10" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Impact Preview" FontSize="10" Foreground="#94a3b8" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="Impact:" FontSize="10" Foreground="#f87171" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                                        <TextBlock Text="{Binding ImpactPreviewExpectedImpact}" FontSize="10" Foreground="#e2e8f0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="Rollback:" FontSize="10" Foreground="#4ade80" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                                        <TextBlock Text="{Binding ImpactPreviewRollbackPath}" FontSize="10" Foreground="#e2e8f0" TextWrapping="Wrap" FontFamily="{Binding RollbackPathFontFamily}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="Verify:" FontSize="10" Foreground="#60a5fa" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                                        <TextBlock Text="{Binding ImpactPreviewVerificationCommand}" FontSize="10" Foreground="#e2e8f0" TextWrapping="Wrap" FontFamily="{Binding ImpactPreviewVerificationFontFamily}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <!-- Apply Commands -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasApplyCommands}"
                                                        Spacing="4">
                                                <TextBlock Text="Apply commands — step-by-step fix:" FontSize="10" Foreground="#f87171" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding RemediationApplyCommands}"
                                                              ItemTemplate="{StaticResource CommandRowTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Rollback Commands -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasRollbackCommands}"
                                                        Spacing="4">
                                                <TextBlock Text="Rollback commands — if something goes wrong:" FontSize="10" Foreground="#4ade80" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding RemediationRollbackCommands}"
                                                              ItemTemplate="{StaticResource CommandRowTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Verification Commands -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasRemediationVerificationCommands}"
                                                        Spacing="4">
                                                <TextBlock Text="Verify the fix:" FontSize="10" Foreground="#64748b" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding RemediationVerificationCommands}"
                                                              ItemTemplate="{StaticResource CommandRowTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Countermeasures -->
                                            <StackPanel Orientation="Vertical"
                                                        IsVisible="{Binding HasCountermeasureCommands}"
                                                        Spacing="4">
                                                <TextBlock Text="Countermeasures — active defense:" FontSize="10" Foreground="#f97316" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding CountermeasureCommands}"
                                                              ItemTemplate="{StaticResource CommandRowTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                                <Button Content="Deploy Countermeasures"
                                                        FontSize="11"
                                                        Padding="8,4"
                                                        Background="#7c2d12"
                                                        Foreground="#fb923c"
                                                        Command="{Binding $parent[ItemsControl].((vm:AgentViewModel)DataContext).DeployCountermeasuresCommand}"
                                                        CommandParameter="{Binding RemediationSection}"/>
                                            </StackPanel>
                                            <!-- Verify Session Button -->
                                            <Button Content="Verify Remediation"
                                                    FontSize="11"
                                                    Padding="8,4"
                                                    Background="#1e3a5f"
                                                    Foreground="#60a5fa"
                                                    IsVisible="{Binding HasActiveSession}"
                                                    Command="{Binding $parent[ItemsControl].((vm:AgentViewModel)DataContext).VerifySessionCommand}"
                                                    CommandParameter="{Binding SessionId}"/>
                                            <!-- Session Timeline -->
                                            <StackPanel Orientation="Vertical"
                                                        Margin="0,8,0,0"
                                                        IsVisible="{Binding HasSessionTimeline}"
                                                        Spacing="4">
                                                <TextBlock Text="Timeline:" FontSize="10" Foreground="#64748b" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding SessionTimeline}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="sessions:RemediationSessionEvent">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="•" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss}}"
                                                                           FontSize="10" Foreground="#64748b" VerticalAlignment="Center"/>
                                                                <TextBlock Text="—" FontSize="10" Foreground="#64748b" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Type}" FontSize="10" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Title}" FontSize="10" Foreground="#e2e8f0" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Quick action buttons -->
            <WrapPanel Grid.Row="2" Margin="8,4,8,0" Orientation="Horizontal">
                <Button Content="Full Audit"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding FullAuditCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentFullAuditButton"/>
                <Button Content="Firewall"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding FirewallCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentFirewallButton"/>
                <Button Content="Ports"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding PortsCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentPortsButton"/>
                <Button Content="Services"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ServicesCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentServicesButton"/>
                <Button Content="Network"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding NetworkCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentNetworkButton"/>
                <Button Content="Containers"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ContainerCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentContainerButton"/>
                <Button Content="Kubernetes"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding KubernetesCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentKubernetesButton"/>
                <Button Content="YARA"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding YaraCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentYaraButton"/>
                <Button Content="Process Runtime"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ProcessRuntimeCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentProcessRuntimeButton"/>
                <Button Content="Threat Intel"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ImportThreatIntelCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        AutomationProperties.AutomationId="AgentThreatIntelButton"/>
                <Button Content="Explain Selected"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ExplainSelectedCommand}"
                        IsEnabled="{Binding CanExplainSelected}"
                        AutomationProperties.AutomationId="AgentExplainSelectedButton"/>
                <Button Content="Export Audit"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ExportAuditCommand}"
                        IsEnabled="{Binding CanExportAudit}"
                        AutomationProperties.AutomationId="AgentExportAuditButton"/>
                <Button Content="Export Remediation"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ExportRemediationCommand}"
                        IsEnabled="{Binding CanExportAudit}"
                        AutomationProperties.AutomationId="AgentExportRemediationButton"/>
                <Button Content="Export Session"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding ExportSessionCommand}"
                        IsEnabled="{Binding CanExportSession}"
                        AutomationProperties.AutomationId="AgentExportSessionButton"/>
                <Button Content="Compare Last Two"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,6,4"
                        Command="{Binding CompareAuditsCommand}"
                        IsEnabled="{Binding CanCompareAudits}"
                        AutomationProperties.AutomationId="AgentCompareAuditsButton"/>
                <Button Content="Compare Selected"
                        FontSize="11"
                        Padding="6,2"
                        Margin="0,0,0,4"
                        Command="{Binding CompareSelectedAuditsCommand}"
                        IsEnabled="{Binding CanCompareSelectedAudits}"
                        AutomationProperties.AutomationId="AgentCompareSelectedButton"/>
            </WrapPanel>

            <!-- Input area -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="8,4,8,8">
                <TextBox Grid.Column="0"
                         Text="{Binding UserQuery, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Ask the agent..."
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         AutomationProperties.AutomationId="AgentQueryTextBox"/>
                <Button Grid.Column="1"
                        Content="Send"
                        Margin="8,0,0,0"
                        Command="{Binding SendQueryCommand}"
                        AutomationProperties.AutomationId="AgentSendButton"/>
                <Button Grid.Column="2"
                        Content="Cancel"
                        Margin="8,0,0,0"
                        Command="{Binding CancelQueryCommand}"
                        IsVisible="{Binding IsBusy}"
                        AutomationProperties.AutomationId="AgentCancelButton"/>
            </Grid>

            <!-- Audit history -->
            <Expander Grid.Row="4"
                      Header="Audit History"
                      Margin="8,0,8,4"
                      IsExpanded="False"
                      Background="#0f172a"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      CornerRadius="6">
                <StackPanel Orientation="Vertical" Margin="4" Spacing="6">
                    <!-- Selectable diff controls -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox ItemsSource="{Binding History}"
                                  SelectedItem="{Binding SelectedBeforeEntry}"
                                  FontSize="11"
                                  Padding="4,2"
                                  Width="140"
                                  PlaceholderText="Before"/>
                        <TextBlock Text="→" VerticalAlignment="Center" Foreground="#94a3b8"/>
                        <ComboBox ItemsSource="{Binding History}"
                                  SelectedItem="{Binding SelectedAfterEntry}"
                                  FontSize="11"
                                  Padding="4,2"
                                  Width="140"
                                  PlaceholderText="After"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding History}" MaxHeight="160">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1e293b"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,4">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss}}"
                                                   Foreground="#94a3b8"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Intent}"
                                                   Foreground="#e2e8f0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalFindings, StringFormat='{}findings: {0}'}"
                                                   Foreground="#94a3b8"
                                                   FontSize="10"
                                                   Margin="8,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding PassedCount, StringFormat='{}passed: {0}'}"
                                                   Foreground="#22c55e"
                                                   FontSize="10"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding SuppressedCount, StringFormat='{}supp: {0}'}"
                                                   Foreground="#64748b"
                                                   FontSize="10"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding WarningCount, StringFormat='{}warn: {0}'}"
                                                   Foreground="#fcd34d"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding CrashedCount, StringFormat='{}crashed: {0}'}"
                                                   Foreground="#f97316"
                                                   FontSize="10"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="7"
                                                   Text="exported"
                                                   Foreground="#22c55e"
                                                   FontSize="10"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding Exported}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- Remediation sessions -->
            <Expander Grid.Row="5"
                      Header="Remediation Sessions"
                      Margin="8,0,8,4"
                      IsExpanded="False"
                      Background="#0f172a"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      CornerRadius="6">
                <StackPanel Orientation="Vertical" Margin="4" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Refresh"
                                FontSize="11"
                                Padding="6,2"
                                Command="{Binding ListSessionsCommand}"
                                IsEnabled="{Binding !IsBusy}"/>
                        <Button Content="Resume"
                                FontSize="11"
                                Padding="6,2"
                                Command="{Binding ResumeSessionCommand}"/>
                        <Button Content="Delete"
                                FontSize="11"
                                Padding="6,2"
                                Command="{Binding DeleteSessionCommand}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding SelectedSession}"
                             MaxHeight="160"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="sessions:RemediationSession">
                                <Border Background="#1e293b"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,4">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SessionId}"
                                                   Foreground="#e2e8f0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RemediationPlan.Sections[0].FindingSummary, FallbackValue='No summary'}"
                                                   Foreground="#94a3b8"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Status}"
                                                   Foreground="#94a3b8"
                                                   FontSize="10"
                                                   Margin="8,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding CreatedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                   Foreground="#64748b"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Expander>
        </Grid>
    </Grid>
</UserControl>
